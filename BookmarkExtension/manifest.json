{
  "manifest_version": 3,
  "name": "Bookmark Manager Sync",
  "version": "0.1.0",
  "description": "Synchronizes selected Brave bookmark folders with Bookmark Manager.",
  "permissions": ["bookmarks", "storage", "alarms", "tabs", "scripting", "activeTab", "downloads", "notifications", "sidePanel"],
  "omnibox": { "keyword": "bm" },
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Bookmark Manager Sync"
  },
  "commands": {
    "quick-bookmark": {
      "suggested_key": {
        "default": "Ctrl+Shift+F"
      },
      "description": "Quick-bookmark current page, or close the extension popup if it is already open"
    },
    "toggle-palette": {
      "suggested_key": {
        "default": "Ctrl+Shift+P"
      },
      "description": "Toggle the in-tab command palette (rebind to Ctrl+P at brave://extensions/shortcuts to override print)"
    },
    "toggle-sidepanel": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      },
      "description": "Toggle the bookmark side panel"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["palette-host.html"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
