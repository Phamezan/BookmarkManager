{
  "manifest_version": 3,
  "name": "Bookmark Manager Sync",
  "version": "0.1.0",
  "description": "Synchronizes selected Brave bookmark folders with Bookmark Manager.",
  "permissions": ["bookmarks", "storage", "alarms", "tabs", "scripting", "activeTab", "downloads"],
  "omnibox": { "keyword": "bm" },
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Bookmark Manager Sync"
  },
  "commands": {
    "quick-bookmark": {
      "suggested_key": {
        "default": "Ctrl+Shift+F"
      },
      "description": "Bookmark current page in the last remembered folder context"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
