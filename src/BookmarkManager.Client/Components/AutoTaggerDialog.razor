@using BookmarkManager.Contracts
@using BookmarkManager.Client.Services
@using MudBlazor
@using System.Threading

<MudDialog Class="auto-tagger-dialog">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Auto Tagger</MudText>
        </div>
    </TitleContent>

    <DialogContent>
        <MudStack Spacing="4">
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Scanning bookmarks for untagged items...</MudText>
            }
            else if (_currentState == TaggerState.Selection && _selectableFolders.Count == 0)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                    All bookmarks are fully tagged! There are no untagged bookmarks found.
                </MudAlert>
            }
            else if (_currentState == TaggerState.Selection)
            {
                <!-- Selection Screen -->
                <MudStack Spacing="3">
                    <div class="d-flex align-center justify-space-between">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">SELECT FOLDERS TO TAG</MudText>
                        <MudCheckBox T="bool" Value="_selectAll" ValueChanged="OnSelectAllChanged" Label="Select All" Color="Color.Primary" Dense="true" />
                    </div>
                    <div style="max-height: 160px; overflow-y: auto; border: 1px solid var(--mud-palette-divider); border-radius: 4px; padding: 8px;">
                        <MudGrid Spacing="1">
                            @foreach (var folder in _selectableFolders)
                            {
                                var isChecked = _selectedFolderIds.Contains(folder.Id);
                                <MudItem xs="12" sm="6">
                                    <MudPaper Outlined="true" Class="pa-2 d-flex align-center justify-space-between" Style="background: transparent;">
                                        <div class="d-flex align-center gap-2 text-truncate">
                                            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" Color="Color.Primary" />
                                            <span class="text-truncate" style="font-size: 0.9rem;">
                                                @folder.Title
                                                <span class="mud-text-secondary" style="font-size: 0.75rem; font-weight: 600; margin-left: 4px;">
                                                    (@_untaggedCounts[folder.Id] untagged)
                                                </span>
                                            </span>
                                        </div>
                                        <MudCheckBox T="bool" Value="isChecked" ValueChanged="@((val) => OnFolderCheckChanged(folder.Id, val))" Color="Color.Primary" Dense="true" />
                                    </MudPaper>
                                </MudItem>
                            }
                        </MudGrid>
                    </div>

                </MudStack>
            }
            else if (_currentState == TaggerState.Tagging)
            {
                <!-- Tagging Screen -->
                <MudStack Spacing="2">
                    <div class="d-flex justify-space-between align-center">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">@_statusText</MudText>
                        <MudText Typo="Typo.caption" Style="font-weight: 600; font-family: monospace;">@_processedCount / @_totalCount bookmarks</MudText>
                    </div>
                    <MudProgressLinear Value="@ProgressPercent" Color="Color.Primary" Size="Size.Medium" Class="my-1" />

                    <div id="tagger-terminal-log" style="height: 200px; background-color: #0b0f19; color: #a5b4fc; font-family: 'JetBrains Mono', Consolas, monospace; font-size: 0.8rem; border-radius: 4px; padding: 10px; overflow-y: auto; line-height: 1.4;">
                        @foreach (var log in _logs)
                        {
                            <div style="margin-bottom: 2px;">
                                <span style="color: #64748b; margin-right: 6px;">[@log.Timestamp]</span>
                                @if (log.Type == LogType.Success)
                                {
                                    <span style="color: #10b981;">@log.Message</span>
                                }
                                else if (log.Type == LogType.Error)
                                {
                                    <span style="color: #ef4444;">@log.Message</span>
                                }
                                else if (log.Type == LogType.Info)
                                {
                                    <span style="color: #38bdf8;">@log.Message</span>
                                }
                                else
                                {
                                    <span>@log.Message</span>
                                }
                            </div>
                        }
                    </div>
                </MudStack>
            }
            else if (_currentState == TaggerState.Review)
            {
                <!-- Review Screen -->
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">REVIEW & ADJUST TAGS</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Review the generated suggestions. Click 'x' to delete, or add tags manually before saving.</MudText>
                    
                    <div style="max-height: 280px; overflow-y: auto; border: 1px solid var(--mud-palette-divider); border-radius: 4px; padding: 8px;">
                        <MudStack Spacing="3">
                            @foreach (var item in _reviewItems)
                            {
                                <AutoTaggerReviewRow Item="item" />
                            }
                        </MudStack>
                    </div>
                </MudStack>
            }
        </MudStack>
    </DialogContent>

    <DialogActions>
        @if (_currentState == TaggerState.Selection)
        {
            <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
            <MudButton Variant="Variant.Filled"
                       Style="background-color: #10b981; color: white;"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       OnClick="StartTaggingAsync"
                       Disabled="@(_loading || _selectedFolderIds.Count == 0)">
                Start Tagging
            </MudButton>
        }
        else if (_currentState == TaggerState.Tagging)
        {
            @if (!_taggingFinished)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Stop" OnClick="StopTagging">Stop Tagging</MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
                <MudButton Variant="Variant.Filled"
                           Style="background-color: #10b981; color: white;"
                           StartIcon="@Icons.Material.Filled.ArrowForward"
                           OnClick="GoToReview">
                    Next
                </MudButton>
            }
        }
        else if (_currentState == TaggerState.Review)
        {
            <MudButton Variant="Variant.Text" OnClick="Cancel">Discard</MudButton>
            <MudButton Variant="Variant.Filled"
                       Style="background-color: #10b981; color: white;"
                       StartIcon="@Icons.Material.Filled.Check"
                       OnClick="ConfirmAndSaveAsync">
                Apply & Save
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Inject] private IBookmarkService BookmarkService { get; set; } = default!;
    [Inject] private IJSRuntime JsRuntime { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private enum TaggerState
    {
        Selection,
        Tagging,
        Review
    }

    private bool _loading = true;
    private TaggerState _currentState = TaggerState.Selection;
    private bool _taggingFinished;
    private bool _isTagging => _currentState == TaggerState.Tagging && !_taggingFinished;
    
    private string _statusText = "Ready to start.";
    private int _processedCount;
    private int _totalCount;
    private bool _selectAll;

    private List<FolderTreeNodeDto> _selectableFolders = [];
    private Dictionary<Guid, int> _untaggedCounts = new();
    private HashSet<Guid> _selectedFolderIds = [];

    private List<TerminalLogEntry> _logs = [];
    private CancellationTokenSource? _cts;

    // Review Mode state
    private List<ReviewItem> _reviewItems = [];

    private double ProgressPercent => _totalCount == 0 ? 0 : ((double)_processedCount / _totalCount) * 100;

    protected override async Task OnInitializedAsync()
    {

        try
        {
            var rawFolders = await BookmarkService.GetFolderTreeAsync();
            _untaggedCounts = await BookmarkService.GetUntaggedCountsAsync();

            var flatFolders = new List<FolderTreeNodeDto>();
            FlattenFolders(rawFolders, flatFolders);

            _selectableFolders = flatFolders
                .Where(f => _untaggedCounts.TryGetValue(f.Id, out var count) && count > 0)
                .ToList();

            foreach (var f in _selectableFolders)
            {
                _selectedFolderIds.Add(f.Id);
            }
            _selectAll = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error scanning database: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void FlattenFolders(List<FolderTreeNodeDto> nodes, List<FolderTreeNodeDto> flatList)
    {
        foreach (var node in nodes)
        {
            flatList.Add(node);
            FlattenFolders(node.Children, flatList);
        }
    }

    private void OnSelectAllChanged(bool val)
    {
        _selectAll = val;
        _selectedFolderIds.Clear();
        if (val)
        {
            foreach (var f in _selectableFolders)
            {
                _selectedFolderIds.Add(f.Id);
            }
        }
    }

    private void OnFolderCheckChanged(Guid id, bool isChecked)
    {
        if (isChecked)
        {
            _selectedFolderIds.Add(id);
        }
        else
        {
            _selectedFolderIds.Remove(id);
            _selectAll = false;
        }
    }

    private async Task StartTaggingAsync()
    {
        _currentState = TaggerState.Tagging;
        _processedCount = 0;
        _totalCount = _selectedFolderIds.Sum(id => _untaggedCounts.GetValueOrDefault(id, 0));
        _logs.Clear();
        _reviewItems.Clear();
        _cts = new CancellationTokenSource();

        AddLog("Initializing Auto Tagger...", LogType.Info);

        try
        {
            foreach (var folderId in _selectedFolderIds)
            {
                _cts.Token.ThrowIfCancellationRequested();

                var folder = _selectableFolders.First(f => f.Id == folderId);
                _statusText = $"Loading '{folder.Title}'...";
                AddLog($"Reading bookmarks in folder '{folder.Title}'...", LogType.Info);
                StateHasChanged();

                var bookmarks = await BookmarkService.GetBookmarksAsync(folderId);
                var untagged = bookmarks
                    .Where(b => b.Type == NodeType.Bookmark && (b.Metadata?.Tags == null || b.Metadata.Tags.Count == 0))
                    .ToList();

                if (untagged.Count == 0)
                {
                    continue;
                }

                _statusText = $"Tagging '{folder.Title}' folder...";
                AddLog($"Found {untagged.Count} untagged bookmarks. Processing...", LogType.Info);
                StateHasChanged();

                for (int i = 0; i < untagged.Count; i += 10)
                {
                    _cts.Token.ThrowIfCancellationRequested();

                    var chunk = untagged.Skip(i).Take(10).ToList();
                    var candidates = chunk.Select(b => new BookmarkTagCandidateDto { Id = b.Id, Title = b.Title, Url = b.Url }).ToList();

                    AddLog($"Processing batch of {chunk.Count} bookmarks...", LogType.Info);
                    StateHasChanged();

                    try
                    {
                        var req = new BatchTagRequest
                        {
                            Items = candidates,
                            FolderId = folderId,
                            FolderPath = folder.Title,
                            Domain = GuessDefaultDomain(folder.Title)
                        };

                        var response = await BookmarkService.TagBatchAsync(req, _cts.Token);
                        foreach (var item in chunk)
                        {
                            var tags = response.Tags.TryGetValue(item.Id, out var t) ? t : new List<string>();
                            if (tags.Count > 0)
                            {
                                AddLog($"✓ '{item.Title}' tagged: [{string.Join(", ", tags)}]", LogType.Success);
                            }
                            else
                            {
                                AddLog($"✗ '{item.Title}' failed to tag (no tags generated)", LogType.Error);
                            }

                            _reviewItems.Add(new ReviewItem
                            {
                                Id = item.Id,
                                Title = item.Title,
                                Url = item.Url ?? string.Empty,
                                Tags = tags
                            });
                        }
                    }
                    catch (Exception ex)
                    {
                        var msg = ex is ApiException apiEx ? (apiEx.Detail ?? apiEx.Title) : ex.Message;
                        AddLog($"Error: {msg}", LogType.Error);
                        foreach (var item in chunk)
                        {
                            _reviewItems.Add(new ReviewItem
                            {
                                Id = item.Id,
                                Title = item.Title,
                                Url = item.Url ?? string.Empty,
                                Tags = new List<string>()
                            });
                        }
                    }

                    _processedCount += chunk.Count;
                    StateHasChanged();
                    await ScrollTerminalToBottomAsync();
                }

                AddLog($"Finished processing folder '{folder.Title}'.", LogType.Success);
                await ScrollTerminalToBottomAsync();
            }

            AddLog("Tag generation complete. Review the activity log above and click 'Next' to continue.", LogType.Success);
            _taggingFinished = true;
        }
        catch (OperationCanceledException)
        {
            AddLog("Tagging cancelled by user.", LogType.Error);
            _taggingFinished = true;
        }
        catch (Exception ex)
        {
            AddLog($"An error occurred during tagging: {ex.Message}", LogType.Error);
            _taggingFinished = true;
        }
        finally
        {
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private void GoToReview()
    {
        _currentState = TaggerState.Review;
    }

    private async Task ConfirmAndSaveAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var saveReq = new BulkSaveTagsRequest
            {
                Tags = _reviewItems.ToDictionary(i => i.Id, i => i.Tags)
            };

            var success = await BookmarkService.BulkSaveTagsAsync(saveReq);
            if (success)
            {
                Snackbar.Add($"Successfully saved tags for {_reviewItems.Count} bookmarks.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Failed to save tags to the database.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving tags: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void StopTagging()
    {
        _cts?.Cancel();
    }

    private void Cancel()
    {
        StopTagging();
        MudDialog.Cancel();
    }

    private void AddLog(string message, LogType type)
    {
        _logs.Add(new TerminalLogEntry
        {
            Timestamp = DateTime.Now.ToString("HH:mm:ss"),
            Message = message,
            Type = type
        });
        StateHasChanged();
    }

    private static BookmarkTagDomainDto GuessDefaultDomain(string folderTitle)
    {
        var value = $" {folderTitle} ".ToLowerInvariant();
        if (value.Contains(" anime ")) return BookmarkTagDomainDto.Anime;
        if (value.Contains(" manga ") || value.Contains(" manhwa ") || value.Contains(" manhua ") || value.Contains(" webtoon ")) return BookmarkTagDomainDto.Manga;
        if (value.Contains(" novel ") || value.Contains(" novels ") || value.Contains(" light novel ") || value.Contains(" web novel ") || value.Contains(" ln ") || value.Contains(" wn ") || value.Contains(" wuxia ") || value.Contains(" xianxia ")) return BookmarkTagDomainDto.Novel;
        return BookmarkTagDomainDto.General;
    }

    private async Task ScrollTerminalToBottomAsync()
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("eval", "const el = document.getElementById('tagger-terminal-log'); if (el) el.scrollTop = el.scrollHeight;");
        }
        catch
        {
            // Ignore JS failures
        }
    }

    private class TerminalLogEntry
    {
        public string Timestamp { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
        public LogType Type { get; set; }
    }

    private enum LogType
    {
        Normal,
        Success,
        Error,
        Info
    }
}
