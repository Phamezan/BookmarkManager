@namespace BookmarkManager.Client.Components
@using BookmarkManager.Contracts
@using BookmarkManager.Client.Services
@using MudBlazor
@using System.Threading

<MudDialog Class="auto-tagger-dialog">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Auto Tagger</MudText>
        </div>
    </TitleContent>

    <DialogContent>
        <MudStack Spacing="4">
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Scanning bookmarks for untagged items...</MudText>
            }
            else if (_currentState == TaggerState.Selection && _selectableFolders.Count == 0)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                    All bookmarks are fully tagged! There are no untagged bookmarks found.
                </MudAlert>
            }
            else if (_currentState == TaggerState.Selection)
            {
                <!-- Selection Screen -->
                <MudStack Spacing="3">
                    <div class="d-flex align-center justify-space-between">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">SELECT FOLDERS TO TAG</MudText>
                        <MudCheckBox T="bool" Value="_selectAll" ValueChanged="OnSelectAllChanged" Label="Select All"
                                     Color="Color.Primary" Dense="true" />
                    </div>
                    <MudSwitch T="bool" @bind-Value="_useAiSeriesAutoTagging" Color="Color.Primary"
                               Label="Use OpenRouter series matching (saves tags directly)" />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        Turn this on to use OpenRouter only for canonical title matching; source providers still supply the
                        tags.
                    </MudText>
                    <div
                        style="max-height: 160px; overflow-y: auto; border: 1px solid var(--mud-palette-divider); border-radius: 4px; padding: 8px;">
                        <MudGrid Spacing="1">
                            @foreach (var folder in _selectableFolders)
                            {
                                var isChecked = _selectedFolderIds.Contains(folder.Id);
                                <MudItem xs="12" sm="6">
                                    <MudPaper Outlined="true" Class="pa-2 d-flex align-center justify-space-between"
                                              Style="background: transparent;">
                                        <div class="d-flex align-center gap-2 text-truncate">
                                            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small"
                                                     Color="Color.Primary" />
                                            <span class="text-truncate" style="font-size: 0.9rem;">
                                                @folder.Title
                                                <span class="mud-text-secondary"
                                                      style="font-size: 0.75rem; font-weight: 600; margin-left: 4px;">
                                                    (@_untaggedCounts[folder.Id] untagged)
                                                </span>
                                            </span>
                                        </div>
                                        <MudCheckBox T="bool" Value="isChecked"
                                                     ValueChanged="@((val) => OnFolderCheckChanged(folder.Id, val))"
                                                     Color="Color.Primary" Dense="true" />
                                    </MudPaper>
                                </MudItem>
                            }
                        </MudGrid>
                    </div>

                </MudStack>
            }
            else if (_currentState == TaggerState.Tagging)
            {
                <!-- Tagging Screen -->
                <MudStack Spacing="2">
                    <div class="d-flex justify-space-between align-center flex-wrap gap-2">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">@_statusText</MudText>
                        <MudText Typo="Typo.caption" Style="font-weight: 600; font-family: monospace;">
                            @_processedCount / @_totalCount bookmarks
                            @if (!string.IsNullOrWhiteSpace(_etaText))
                            {
                                <span class="mud-text-secondary"> · @_etaText</span>
                            }
                        </MudText>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_currentBookmarkTitle))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-family: monospace;">
                            Current: @_currentBookmarkTitle
                        </MudText>
                    }

                    <MudProgressLinear Value="@ProgressPercent" Color="Color.Primary" Size="Size.Medium" Class="my-1" />

                    @if (_rateLimitStopped)
                    {
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="my-2">
                            Rate limit hit! AI auto-tagging has been paused.
                            <br />
                            <strong>@_remainingCount</strong> bookmark(s) remain to be tagged.
                            <br />
                            Please wait a bit (e.g. 60 seconds), close this dialog, and run the Auto Tagger again to resume.
                        </MudAlert>
                    }

                    <div id="tagger-terminal-log"
                                 style="height: 200px; background-color: #0b0f19; color: #a5b4fc; font-family: 'JetBrains Mono', Consolas, monospace; font-size: 0.8rem; border-radius: 4px; padding: 10px; overflow-y: auto; line-height: 1.4;">
                        @foreach (var log in _logs)
                        {
                            <div style="margin-bottom: 2px;">
                                <span style="color: #64748b; margin-right: 6px;">[@log.Timestamp]</span>
                                @if (log.Type == LogType.Success)
                                {
                                    <span style="color: #10b981;">@log.Message</span>
                                }
                                else if (log.Type == LogType.Error)
                                {
                                    <span style="color: #ef4444;">@log.Message</span>
                                }
                                else if (log.Type == LogType.Info)
                                {
                                    <span style="color: #38bdf8;">@log.Message</span>
                                }
                                else
                                {
                                    <span>@log.Message</span>
                                }
                            </div>
                        }
                    </div>
                </MudStack>
            }
            else if (_currentState == TaggerState.Review)
            {
                <!-- Review Screen -->
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">REVIEW & ADJUST TAGS</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Review the generated suggestions. Click 'x' to
                        delete, or add tags manually before saving.</MudText>

                    <div
                        style="max-height: 300px; overflow-y: auto; border: 1px solid var(--mud-palette-divider); border-radius: 4px; padding: 8px;">
                        <MudStack Spacing="3">
                            @foreach (var item in _reviewItems)
                            {
                                <AutoTaggerReviewRow Item="item" />
                            }
                        </MudStack>
                    </div>
                </MudStack>
            }
        </MudStack>
    </DialogContent>

                <DialogActions>
                    @if (_currentState == TaggerState.Selection)
                    {
                        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Style="background-color: #10b981; color: white;"
                                   StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="StartTaggingAsync"
                                   Disabled="@(_loading || _selectedFolderIds.Count == 0)">
                            Start Tagging
                        </MudButton>
                    }
                    else if (_currentState == TaggerState.Tagging)
                    {
                        @if (!_taggingFinished)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.Stop"
                                       OnClick="StopTagging">Stop Tagging</MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
                            @if (_useAiSeriesAutoTagging)
                            {
                                <MudButton Variant="Variant.Filled" Style="background-color: #10b981; color: white;"
                                           StartIcon="@Icons.Material.Filled.Check" OnClick="Cancel">
                                    Close
                                </MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Filled" Style="background-color: #10b981; color: white;"
                                           StartIcon="@Icons.Material.Filled.ArrowForward" OnClick="GoToReview">
                                    Next
                                </MudButton>
                            }
                        }
                    }
                    else if (_currentState == TaggerState.Review)
                    {
                        <MudButton Variant="Variant.Text" OnClick="Cancel">Discard</MudButton>
                        <MudButton Variant="Variant.Filled" Style="background-color: #10b981; color: white;"
                                   StartIcon="@Icons.Material.Filled.Check" OnClick="ConfirmAndSaveAsync">
                            Apply & Save
                        </MudButton>
                    }
                </DialogActions>
            </MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Guid? CurrentFolderId { get; set; }
    [Inject] private IBookmarkService BookmarkService { get; set; } = default!;
    [Inject] private IJSRuntime JsRuntime { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private enum TaggerState
    {
        Selection,
        Tagging,
        Review
    }

    private bool _loading = true;
    private TaggerState _currentState = TaggerState.Selection;
    private bool _taggingFinished;
    private bool _isTagging => _currentState == TaggerState.Tagging && !_taggingFinished;

    private string _statusText = "Ready to start.";
    private int _processedCount;
    private int _totalCount;
    private bool _selectAll;
    private bool _useAiSeriesAutoTagging = true;
    private bool _rateLimitStopped;
    private int _remainingCount;
    private int _preferredBatchSize = 25;
    private DateTimeOffset _taggingStartedAt;
    private string? _etaText;
    private string? _currentBookmarkTitle;

    private List<FolderTreeNodeDto> _selectableFolders = [];
    private Dictionary<Guid, int> _untaggedCounts = new();
    private HashSet<Guid> _selectedFolderIds = [];

    private List<TerminalLogEntry> _logs = [];
    private CancellationTokenSource? _cts;

    // Review Mode state
    private List<ReviewItem> _reviewItems = [];

    private double ProgressPercent => _totalCount == 0 ? 0 : ((double)_processedCount / _totalCount) * 100;

    protected override async Task OnInitializedAsync()
    {

        try
        {
            var rawFolders = await BookmarkService.GetFolderTreeAsync();
            _untaggedCounts = await BookmarkService.GetUntaggedCountsAsync();
            var aiSettings = await BookmarkService.GetAiTaggingSettingsAsync();
            _useAiSeriesAutoTagging = aiSettings.Enabled;
            _preferredBatchSize = aiSettings.PreferredBatchSize > 0 ? aiSettings.PreferredBatchSize : 25;

            var flatFolders = new List<FolderTreeNodeDto>();
            FlattenFolders(rawFolders, flatFolders);

            _selectableFolders = flatFolders
                .Where(f => _untaggedCounts.TryGetValue(f.Id, out var count) && count > 0)
                .ToList();

            _selectedFolderIds.Clear();
            if (CurrentFolderId.HasValue && _selectableFolders.Any(folder => folder.Id == CurrentFolderId.Value))
            {
                _selectedFolderIds.Add(CurrentFolderId.Value);
            }
            _selectAll = _selectableFolders.Count > 0 && _selectedFolderIds.Count == _selectableFolders.Count;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error scanning database: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void FlattenFolders(List<FolderTreeNodeDto> nodes, List<FolderTreeNodeDto> flatList)
    {
        // Skip root-level nodes (Bookmarks Bar, Other Bookmarks, Mobile Bookmarks)
        // — selecting them would tag every descendant folder at once.
        foreach (var node in nodes)
        {
            FlattenChildren(node.Children, flatList);
        }
    }

    private void FlattenChildren(List<FolderTreeNodeDto> nodes, List<FolderTreeNodeDto> flatList)
    {
        foreach (var node in nodes)
        {
            flatList.Add(node);
            FlattenChildren(node.Children, flatList);
        }
    }

    private void OnSelectAllChanged(bool val)
    {
        _selectAll = val;
        _selectedFolderIds.Clear();
        if (val)
        {
            foreach (var f in _selectableFolders)
            {
                _selectedFolderIds.Add(f.Id);
            }
        }
    }

    private void OnFolderCheckChanged(Guid id, bool isChecked)
    {
        if (isChecked)
        {
            _selectedFolderIds.Add(id);
        }
        else
        {
            _selectedFolderIds.Remove(id);
            _selectAll = false;
        }
    }

    private async Task StartTaggingAsync()
    {
        _currentState = TaggerState.Tagging;
        _processedCount = 0;
        _totalCount = _selectedFolderIds.Sum(id => _untaggedCounts.GetValueOrDefault(id, 0));
        _logs.Clear();
        _reviewItems.Clear();
        _cts = new CancellationTokenSource();
        _rateLimitStopped = false;
        _remainingCount = 0;
        _taggingStartedAt = DateTimeOffset.UtcNow;
        _etaText = null;
        _currentBookmarkTitle = null;

        AddLog(_useAiSeriesAutoTagging
            ? "Initializing OpenRouter series-matching Auto Tagger..."
            : "Initializing Auto Tagger...", LogType.Info);

        try
        {
            if (_useAiSeriesAutoTagging)
            {
                await RunAiSeriesAutoTaggingAsync();
                return;
            }

            foreach (var folderId in _selectedFolderIds)
            {
                _cts.Token.ThrowIfCancellationRequested();

                var folder = _selectableFolders.First(f => f.Id == folderId);
                _statusText = $"Loading '{folder.Title}'...";
                AddLog($"Reading bookmarks in folder '{folder.Title}'...", LogType.Info);
                StateHasChanged();

                var bookmarks = await BookmarkService.GetBookmarksAsync(folderId);
                var untagged = bookmarks
                    .Where(b => b.Type == NodeType.Bookmark && (b.Metadata?.Tags == null || b.Metadata.Tags.Count == 0))
                    .ToList();

                if (untagged.Count == 0)
                {
                    continue;
                }

                _statusText = $"Tagging '{folder.Title}' folder...";
                AddLog($"Found {untagged.Count} untagged bookmarks. Processing...", LogType.Info);
                StateHasChanged();

                for (int i = 0; i < untagged.Count; i += 10)
                {
                    _cts.Token.ThrowIfCancellationRequested();

                    var chunk = untagged.Skip(i).Take(10).ToList();
                    var candidates = chunk.Select(b => new BookmarkTagCandidateDto { Id = b.Id, Title = b.Title, Url = b.Url }).ToList();

                    AddLog($"Processing batch of {chunk.Count} bookmarks...", LogType.Info);
                    StateHasChanged();

                    try
                    {
                        var req = new BatchTagRequest
                        {
                            Items = candidates,
                            FolderId = folderId,
                            FolderPath = null,
                            Domain = BookmarkTagDomainDto.Auto
                        };

                        var response = await BookmarkService.TagBatchAsync(req, _cts.Token);
                        foreach (var item in chunk)
                        {
                            var tags = response.Tags.TryGetValue(item.Id, out var t) ? t : new List<string>();
                            if (tags.Count > 0)
                            {
                                AddLog($"✓ '{item.Title}' tagged: [{string.Join(", ", tags)}]", LogType.Success);
                            }
                            else
                            {
                                AddLog($"✗ '{item.Title}' failed to tag (no tags generated)", LogType.Error);
                            }

                            _reviewItems.Add(new ReviewItem
                            {
                                Id = item.Id,
                                Title = item.Title,
                                Url = item.Url ?? string.Empty,
                                Tags = tags
                            });
                        }
                    }
                    catch (Exception ex)
                    {
                        var msg = ex is ApiException apiEx ? (apiEx.Detail ?? apiEx.Title) : ex.Message;
                        AddLog($"Error: {msg}", LogType.Error);
                        foreach (var item in chunk)
                        {
                            _reviewItems.Add(new ReviewItem
                            {
                                Id = item.Id,
                                Title = item.Title,
                                Url = item.Url ?? string.Empty,
                                Tags = new List<string>()
                            });
                        }
                    }

                    _processedCount += chunk.Count;
                    UpdateProgressMetrics();
                    StateHasChanged();
                    await ScrollTerminalToBottomAsync();
                }

                AddLog($"Finished processing folder '{folder.Title}'.", LogType.Success);
                await ScrollTerminalToBottomAsync();
            }

            AddLog("Tag generation complete. Review the activity log above and click 'Next' to continue.", LogType.Success);
            _taggingFinished = true;
        }
        catch (OperationCanceledException)
        {
            AddLog("Tagging cancelled by user.", LogType.Error);
            _taggingFinished = true;
        }
        catch (Exception ex)
        {
            AddLog($"An error occurred during tagging: {ex.Message}", LogType.Error);
            _taggingFinished = true;
        }
        finally
        {
            _cts?.Dispose();
            _cts = null;
            StateHasChanged();
        }
    }

    private async Task RunAiSeriesAutoTaggingAsync()
    {
        const int maxUiBatchSize = 10;
        int batchSize = Math.Clamp(_preferredBatchSize, 1, maxUiBatchSize);
        bool stoppedEarly = false;

        if (_preferredBatchSize > maxUiBatchSize)
        {
            AddLog($"Using batch size {batchSize} for live progress (settings allow up to {_preferredBatchSize}).", LogType.Info);
        }

        foreach (var folderId in _selectedFolderIds)
        {
            _cts!.Token.ThrowIfCancellationRequested();

            var folder = _selectableFolders.First(f => f.Id == folderId);
            var excludedBookmarkIds = new HashSet<Guid>();
            var folderProcessed = 0;
            var totalTagged = 0;
            var totalAlreadyTagged = 0;
            var totalLowConfidence = 0;
            var totalNoSourceTags = 0;
            var totalFailedChunks = 0;
            var folderTotal = _untaggedCounts.GetValueOrDefault(folderId, 0);

            _statusText = $"AI tagging '{folder.Title}'...";
            AddLog($"Running OpenRouter series matching for '{folder.Title}'...", LogType.Info);
            AddLog($"Processing in batches of {batchSize}; progress updates after each bookmark in a batch.", LogType.Info);
            StateHasChanged();

            var batchNumber = 1;
            while (true)
            {
                _cts.Token.ThrowIfCancellationRequested();
                _currentBookmarkTitle = null;
                AddLog($"→ Batch {batchNumber}: requesting up to {batchSize} bookmark(s) from server...", LogType.Info);
                StateHasChanged();
                await ScrollTerminalToBottomAsync();

                var summary = await RequestAiBatchWithHeartbeatAsync(folderId, batchSize, excludedBookmarkIds, batchNumber);

                if (summary.StopForRateLimit)
                {
                    _rateLimitStopped = true;
                    _remainingCount = _totalCount - _processedCount;
                    AddLog("OpenRouter rate limit reached. Pausing tagging to avoid further errors.", LogType.Error);
                    AddLog($"[INFO] {_remainingCount} bookmark(s) remain untagged.", LogType.Info);
                    AddLog("[INFO] Please wait a moment (e.g. 60 seconds) and run the Auto Tagger again to resume.", LogType.Info);
                    stoppedEarly = true;
                    break;
                }

                await ApplyBatchProgressAsync(summary, batchNumber, excludedBookmarkIds);

                var processedThisBatch = summary.ProcessedBookmarkIds.Count;
                folderProcessed += processedThisBatch;
                totalTagged += summary.Tagged;
                totalAlreadyTagged += summary.SkippedAlreadyTagged;
                totalLowConfidence += summary.SkippedLowConfidence;
                totalNoSourceTags += summary.SkippedNoSourceTags;
                totalFailedChunks += summary.FailedChunks;

                AddLog(
                    $"✓ Batch {batchNumber} returned: processed {processedThisBatch}, tagged {summary.Tagged}, low confidence {summary.SkippedLowConfidence}, no source tags {summary.SkippedNoSourceTags}, failed chunks {summary.FailedChunks}.",
                    summary.Tagged > 0 ? LogType.Success : LogType.Info);

                _statusText = $"AI tagging '{folder.Title}' ({folderProcessed} / {folderTotal})...";
                UpdateProgressMetrics(summary.RemainingCandidates);
                StateHasChanged();
                await ScrollTerminalToBottomAsync();

                if (processedThisBatch == 0)
                {
                    _rateLimitStopped = false;
                    _remainingCount = _totalCount - _processedCount;
                    AddLog("No bookmarks were processed in this batch. Stopping so these bookmarks can be retried later instead of being skipped.", summary.FailedChunks > 0 ? LogType.Error : LogType.Info);
                    stoppedEarly = true;
                    break;
                }

                if (!summary.HasMore)
                    break;

                batchNumber++;
            }

            if (stoppedEarly)
            {
                break;
            }

            AddLog(
                $"✓ '{folder.Title}' complete: tagged {totalTagged}, already tagged {totalAlreadyTagged}, low confidence {totalLowConfidence}, no source tags {totalNoSourceTags}, failed chunks {totalFailedChunks}.",
                totalTagged > 0 ? LogType.Success : LogType.Info);
            StateHasChanged();
            await ScrollTerminalToBottomAsync();
        }

        _currentBookmarkTitle = null;
        if (!stoppedEarly)
        {
            AddLog("AI auto-tagging complete. Tags were saved directly to the database.", LogType.Success);
        }
        else
        {
            AddLog("AI auto-tagging paused. Completed bookmarks were saved; rerun to resume.", LogType.Error);
        }
        _taggingFinished = true;
    }

    private async Task<AiAutoTagSummaryDto> RequestAiBatchWithHeartbeatAsync(
        Guid folderId,
        int batchSize,
        HashSet<Guid> excludedBookmarkIds,
        int batchNumber)
    {
        var batchStarted = DateTimeOffset.UtcNow;
        var requestTask = BookmarkService.AiAutoTagFolderBatchAsync(folderId, new AiAutoTagBatchRequestDto
        {
            ForceRefresh = false,
            MaxCandidates = batchSize,
            ExcludedBookmarkIds = excludedBookmarkIds.ToList()
        }, _cts!.Token);

        using var heartbeat = new PeriodicTimer(TimeSpan.FromSeconds(1));
        while (!requestTask.IsCompleted)
        {
            if (!await heartbeat.WaitForNextTickAsync(_cts.Token).ConfigureAwait(false))
                break;

            var elapsed = DateTimeOffset.UtcNow - batchStarted;
            _statusText = $"AI batch {batchNumber} in progress ({elapsed:mm\\:ss} elapsed)...";
            UpdateProgressMetrics();
            await InvokeAsync(StateHasChanged);
        }

        return await requestTask.ConfigureAwait(false);
    }

    private async Task ApplyBatchProgressAsync(
        AiAutoTagSummaryDto summary,
        int batchNumber,
        HashSet<Guid> excludedBookmarkIds)
    {
        foreach (var id in summary.ProcessedBookmarkIds)
            _cts!.Token.ThrowIfCancellationRequested();

        var statusById = summary.BookmarkStatuses
            .GroupBy(status => status.BookmarkId)
            .ToDictionary(group => group.Key, group => group.Last());

        foreach (var bookmarkId in summary.ProcessedBookmarkIds)
        {
            _cts!.Token.ThrowIfCancellationRequested();

            if (statusById.TryGetValue(bookmarkId, out var status))
            {
                _currentBookmarkTitle = status.Title;
                var logType = status.Status is "DeterministicClassified" or "AiIdentified"
                    ? LogType.Success
                    : status.Status is "RateLimited" or "ProviderFailed" or "AiInvalidResponse"
                        ? LogType.Error
                        : LogType.Info;
                AddLog($"[{batchNumber}] {status.Title}: {status.Status} — {status.Reason}", logType);
            }
            else
            {
                _currentBookmarkTitle = $"Bookmark {bookmarkId}";
                AddLog($"[{batchNumber}] Processed bookmark {bookmarkId}", LogType.Info);
            }

            _processedCount++;
            UpdateProgressMetrics(summary.RemainingCandidates);
            await InvokeAsync(StateHasChanged);
            await ScrollTerminalToBottomAsync();
        }

        foreach (var id in summary.ProcessedBookmarkIds)
            excludedBookmarkIds.Add(id);

        foreach (var message in summary.Messages.Where(message =>
                     !message.StartsWith("Prefetching provider tags", StringComparison.Ordinal) &&
                     !message.StartsWith("Deterministic pass:", StringComparison.Ordinal) &&
                     !message.StartsWith("AI pass:", StringComparison.Ordinal) &&
                     !message.StartsWith("Found ", StringComparison.Ordinal) &&
                     !message.StartsWith("Processing next ", StringComparison.Ordinal) &&
                     !message.StartsWith("Finished with ", StringComparison.Ordinal) &&
                     !message.StartsWith("Run ", StringComparison.Ordinal) &&
                     !message.StartsWith("Provider timing:", StringComparison.Ordinal)))
        {
            var logType = message.Contains('✓', StringComparison.Ordinal) ? LogType.Success
                : message.Contains('✗', StringComparison.Ordinal) ? LogType.Error
                : LogType.Info;
            AddLog(message, logType);
        }
    }

    private void UpdateProgressMetrics(int? serverRemaining = null)
    {
        var remaining = serverRemaining ?? Math.Max(0, _totalCount - _processedCount);
        if (_processedCount <= 0 || remaining <= 0)
        {
            _etaText = remaining <= 0 ? "finishing..." : "estimating...";
            return;
        }

        var elapsed = DateTimeOffset.UtcNow - _taggingStartedAt;
        if (elapsed.TotalSeconds < 2)
        {
            _etaText = "estimating...";
            return;
        }

        var secondsPerBookmark = elapsed.TotalSeconds / _processedCount;
        var etaSeconds = secondsPerBookmark * remaining;
        _etaText = $"~{FormatDuration(TimeSpan.FromSeconds(etaSeconds))} remaining";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalHours >= 1)
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        if (duration.TotalMinutes >= 1)
            return $"{(int)duration.TotalMinutes}m {duration.Seconds}s";
        return $"{Math.Max(1, (int)Math.Ceiling(duration.TotalSeconds))}s";
    }

    private void GoToReview()
    {
        _currentState = TaggerState.Review;
    }

    private async Task ConfirmAndSaveAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var saveReq = new BulkSaveTagsRequest
            {
                Tags = _reviewItems.ToDictionary(i => i.Id, i => i.Tags)
            };

            var success = await BookmarkService.BulkSaveTagsAsync(saveReq);
            if (success)
            {
                Snackbar.Add($"Successfully saved tags for {_reviewItems.Count} bookmarks.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Failed to save tags to the database.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving tags: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void StopTagging()
    {
        _cts?.Cancel();
    }

    private void Cancel()
    {
        StopTagging();
        MudDialog.Cancel();
    }

    private void AddLog(string message, LogType type)
    {
        _logs.Add(new TerminalLogEntry
        {
            Timestamp = DateTime.Now.ToString("HH:mm:ss"),
            Message = message,
            Type = type
        });
        StateHasChanged();
    }

    private async Task ScrollTerminalToBottomAsync()
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("eval", "const el = document.getElementById('tagger-terminal-log'); if (el) el.scrollTop = el.scrollHeight;");
        }
        catch
        {
            // Ignore JS failures
        }
    }

    private class TerminalLogEntry
    {
        public string Timestamp { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
        public LogType Type { get; set; }
    }

    private enum LogType
    {
        Normal,
        Success,
        Error,
        Info
    }
}
