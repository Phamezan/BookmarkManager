<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(Node == null ? "Create Bookmark" : "Edit Bookmark")</MudText>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_valid">
            <MudTextField @bind-Value="_title" Label="Title" Variant="Variant.Outlined"
                          Required="true" RequiredError="Title is required" Class="mb-4" />

            <MudTextField @bind-Value="_url" Label="URL" Variant="Variant.Outlined"
                          Placeholder="https://" Class="mb-4" />

            <div class="mb-4">
                <MudText Typo="Typo.body2" Class="mb-1">Tags</MudText>
                <div class="d-flex flex-wrap gap-1 mb-2">
                    @foreach (var tag in _tags)
                    {
                        <MudChip T="string" Color="Color.Primary" OnClose="@(() => RemoveTag(tag))">@tag</MudChip>
                    }
                    @if (_tags.Count == 0)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">No tags added yet.</MudText>
                    }
                </div>
                <div class="d-flex gap-2">
                    <MudTextField @bind-Value="_newTag" Label="New Tag" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  OnKeyDown="OnTagInputKeyDown" />
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="AddTag">Add</MudButton>
                </div>
            </div>

            <div class="mb-4">
                <div class="d-flex align-center justify-space-between mb-1">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">AI Tag Suggestions</MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="GenerateTagSuggestions" Disabled="@(string.IsNullOrWhiteSpace(_title))">
                        Generate Suggestions
                    </MudButton>
                </div>
                @if (_suggestedTags.Count > 0)
                {
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var tag in _suggestedTags)
                        {
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary" OnClick="@(() => AddSuggestedTag(tag))" Style="cursor: pointer;">@tag</MudChip>
                        }
                    </div>
                }
            </div>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@(!_valid)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private IBookmarkService BookmarkService { get; set; } = default!;
    [Parameter] public BookmarkNodeDto? Node { get; set; }
    [Parameter] public EventCallback<BookmarkEditResult> OnSave { get; set; }
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm _form = default!;
    private bool _valid;

    private string _title = "";
    private string? _url;
    private List<string> _tags = [];
    private string _newTag = "";
    private List<string> _suggestedTags = [];

    protected override void OnParametersSet()
    {
        if (Node != null)
        {
            _title = Node.Title;
            _url = Node.Url;
            _tags = Node.Metadata?.Tags != null ? new List<string>(Node.Metadata.Tags) : [];
        }
    }

    private async Task GenerateTagSuggestions()
    {
        if (string.IsNullOrWhiteSpace(_title)) return;
        try
        {
            _suggestedTags = await BookmarkService.SuggestTagsAsync(_title, _url);
            StateHasChanged();
        }
        catch
        {
            // Ignore suggestion failures
        }
    }

    private void AddTag()
    {
        if (!string.IsNullOrWhiteSpace(_newTag))
        {
            var cleaned = _newTag.Trim();
            if (!_tags.Contains(cleaned, StringComparer.OrdinalIgnoreCase))
            {
                _tags.Add(cleaned);
            }
            _newTag = "";
        }
    }

    private void RemoveTag(string tag)
    {
        _tags.Remove(tag);
    }

    private void AddSuggestedTag(string tag)
    {
        if (!_tags.Contains(tag, StringComparer.OrdinalIgnoreCase))
        {
            _tags.Add(tag);
        }
        _suggestedTags.Remove(tag);
    }

    private void OnTagInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTag();
        }
    }

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_valid) return;

        var result = new BookmarkEditResult
        {
            Title = _title,
            Url = string.IsNullOrWhiteSpace(_url) ? null : _url,
            Tags = _tags
        };

        await OnSave.InvokeAsync(result);
        MudDialog.Close(DialogResult.Ok(result));
    }

    private void Cancel() => MudDialog.Cancel();

    public class BookmarkEditResult
    {
        public string Title { get; set; } = "";
        public string? Url { get; set; }
        public List<string> Tags { get; set; } = [];
    }
}
