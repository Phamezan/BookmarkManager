@using BookmarkManager.Contracts
@using BookmarkManager.Client.Services
@using Microsoft.AspNetCore.Components.Web.Virtualization
@inject ICommandPaletteService PaletteService
@inject IBookmarkService BookmarkService
@inject PaletteFrecencyService FrecencyService
@inject PaletteSearchHistoryService SearchHistoryService
@inject NavigationManager NavigationManager
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<div class="palette-wrapper @(PaletteService.IsOpen ? "is-open" : "") @(Embedded ? "embedded" : "")" id="paletteWrapper">
    <div class="palette-backdrop" @onclick="ClosePalette"></div>
    <div class="palette-modal">
        <!-- Search input -->
        <div class="palette-search-container">
            <MudIcon Icon="@Icons.Material.Filled.Search" Class="palette-search-icon" />
            <input 
                id="paletteSearchInput"
                type="text" 
                class="palette-input" 
                placeholder="Search bookmarks or pick a folder..." 
                value="@_searchQuery"
                @oninput="HandleSearchInput"
                autocomplete="off"
            />
            <kbd class="palette-key">ESC</kbd>
        </div>

        <!-- Scrollable content -->
        <div class="palette-content">
            <div class="palette-header">
                <span class="palette-header-title">@_listHeaderTitle</span>
                <span class="palette-header-count">@_results.Count matches</span>
            </div>

            <div class="palette-list" id="paletteList" style="--palette-item-stride: @(ItemSizePx)px">
                @if (_results.Count == 0)
                {
                    <div class="palette-no-results">
                        @if (string.IsNullOrWhiteSpace(_searchQuery))
                        {
                            <span>No folders found</span>
                        }
                        else
                        {
                            <span>No bookmarks found matching "@_searchQuery"</span>
                        }
                    </div>
                }
                else
                {
                    <Virtualize Items="_results" ItemSize="ItemSizePx" Context="item">
                        @if (item.IsSectionHeader)
                        {
                            <div class="palette-item palette-section-header" aria-hidden="true">
                                <span class="palette-section-title">@item.SectionTitle</span>
                            </div>
                        }
                        else
                        {
                            var isActive = item.Index == _selectedIndex;
                            var badgeClass = GetBadgeClass(item.Category);
                            var useStagger = _triggerStagger && item.Index < 10;
                            var delayStyle = useStagger ? $"animation-delay: {item.Index * 30}ms;" : "";
                            <div class="palette-item @(isActive ? "is-active" : "") @(useStagger ? "stagger-item" : "")"
                                 style="@delayStyle"
                                 title="@(item.Tooltip ?? "")"
                                 @onclick="() => HandleItemClick(item.Index)"
                                 @onmouseover="() => _selectedIndex = item.Index">

                                <div class="palette-item-left">
                                    <div class="palette-item-icon-wrap">
                                        @if (item.IsFolder)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Folder" />
                                        }
                                        else if (GetFaviconUrl(item.Url) is { } favicon)
                                        {
                                            <img src="@favicon" alt="" width="16" height="16" style="border-radius: 2px; object-fit: contain;" onerror="this.style.display='none'" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Bookmark" />
                                        }
                                    </div>
                                    <div class="palette-item-info">
                                        <div class="palette-item-title-row">
                                            <span class="palette-item-title">@item.TitleHtml</span>
                                            @if (!string.IsNullOrWhiteSpace(item.Category))
                                            {
                                                <span class="palette-item-badge @badgeClass">@item.Category</span>
                                            }
                                        </div>
                                        <span class="palette-item-subtitle">@item.Subtitle</span>
                                    </div>
                                </div>

                                @if (isActive)
                                {
                                    <span class="palette-item-indicator">Selected</span>
                                }
                            </div>
                        }
                    </Virtualize>
                    @if (HasMoreResults)
                    {
                        <button type="button" class="palette-load-more" @onclick="LoadMoreResultsAsync" disabled="@_isLoadingMore">
                            @(_isLoadingMore ? "Loading..." : $"Load more ({_totalResultCount - _loadedBookmarkCount} remaining)")
                        </button>
                    }
                }
            </div>
        </div>

        <!-- Footer: same chrome everywhere. Left nav hints removed so dashboard
             Ctrl+P matches the extension overlay. ↑ Recent sits with actions. -->
        <div class="palette-footer">
            <div class="palette-footer-actions">
                @if (string.IsNullOrEmpty(_searchQuery) && _hasSearchHistory)
                {
                    <div class="palette-footer-hint">
                        <kbd class="palette-key">↑</kbd>
                        <span>Recent searches</span>
                    </div>
                }
                <div class="palette-footer-hint">
                    <kbd class="palette-key">Enter</kbd>
                    <span>@_primaryHint</span>
                </div>
                <div class="palette-footer-hint">
                    <kbd class="palette-key">Shift</kbd> + <kbd class="palette-key">Enter</kbd>
                    <span>@_secondaryHint</span>
                </div>
                <div class="palette-footer-hint">
                    <kbd class="palette-key">Ctrl</kbd> + <kbd class="palette-key">Enter</kbd>
                    <span>@_tertiaryHint</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .palette-wrapper {
        position: fixed;
        inset: 0;
        z-index: 2000;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 15vh;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s ease-out;
    }
    .palette-wrapper.is-open {
        pointer-events: auto;
        opacity: 1;
    }
    .palette-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        opacity: 0;
        transition: opacity 0.3s ease-out;
    }
    .palette-wrapper.is-open .palette-backdrop {
        opacity: 1;
    }
    .palette-modal {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 760px;
        margin: 0 16px;
        background: rgba(21, 18, 27, 0.75);
        backdrop-filter: blur(32px);
        -webkit-backdrop-filter: blur(32px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        box-shadow: 0 0 80px rgba(139, 92, 246, 0.1), 0 20px 50px rgba(0, 0, 0, 0.6);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transform: scale(0.95) translateY(-20px);
        opacity: 0;
        transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.35s ease-out;
    }
    .palette-wrapper.is-open .palette-modal {
        transform: scale(1) translateY(0);
        opacity: 1;
    }
    
    .palette-search-container {
        padding: 14px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .palette-search-icon {
        color: #d0bcff;
        font-size: 28px;
    }
    .palette-input {
        width: 100%;
        background: transparent;
        border: none !important;
        outline: none !important;
        box-shadow: none !important;
        padding: 0;
        font-size: 17px;
        font-weight: 500;
        color: #fff;
        caret-color: #d0bcff;
    }
    .palette-input::placeholder {
        color: rgba(203, 195, 215, 0.3);
    }
    
    .palette-content {
        padding: 8px;
    }
    .palette-header {
        padding: 8px 16px;
        display: flex;
        justify-content: space-between;
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .palette-header-title {
        color: rgba(203, 195, 215, 0.5);
    }
    .palette-header-count {
        color: rgba(203, 195, 215, 0.4);
    }
    .palette-list {
        display: block;
        max-height: 420px;
        overflow-y: auto;
    }
    
    /* Scrollbar */
    .palette-list::-webkit-scrollbar {
        width: 6px;
    }
    .palette-list::-webkit-scrollbar-track {
        background: transparent;
    }
    .palette-list::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 9999px;
    }
    
    .palette-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 12px;
        margin-bottom: 4px;
        box-sizing: border-box;
        /* Stride = ItemSizePx; height = stride - margin-bottom so Virtualize math stays honest. */
        height: calc(var(--palette-item-stride, 52px) - 4px);
        border: 1px solid transparent;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.15s ease-out;
        text-decoration: none !important;
    }
    .palette-section-header {
        cursor: default;
        pointer-events: none;
        background: transparent;
        border-color: transparent;
        box-shadow: none;
        opacity: 0.9;
    }
    .palette-section-header:hover {
        background: transparent;
    }
    .palette-section-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgba(203, 195, 215, 0.5);
        padding-left: 4px;
    }
    .palette-item:hover {
        background: rgba(255, 255, 255, 0.05);
    }
    .palette-item.is-active {
        background: rgba(208, 188, 255, 0.08);
        border-color: rgba(208, 188, 255, 0.25);
        box-shadow: inset 0 0 12px rgba(208, 188, 255, 0.05);
    }
    
    .palette-item-left {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
        flex: 1;
    }
    .palette-item-icon-wrap {
        width: 32px;
        height: 32px;
        flex-shrink: 0;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(203, 195, 215, 0.7);
        transition: background 0.15s ease;
    }
    .palette-item:hover .palette-item-icon-wrap {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
    }
    .palette-item.is-active .palette-item-icon-wrap {
        background: rgba(208, 188, 255, 0.2);
        color: #d0bcff;
    }
    
    .palette-item-info {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        min-width: 0;
        flex: 1;
    }
    .palette-item-title-row {
        display: flex;
        align-items: center;
        gap: 8px;
        max-width: 100%;
        min-width: 0;
    }
    .palette-item-title {
        font-size: 14px;
        font-weight: 500;
        color: #e7e0ed;
        transition: color 0.15s ease;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        min-width: 0;
    }
    .palette-highlight {
        background: rgba(208, 188, 255, 0.25);
        color: #fff;
        border-radius: 3px;
        padding: 0 1px;
    }
    .palette-item.is-active .palette-item-title {
        color: #fff;
    }
    .palette-item-badge {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        padding: 2px 6px;
        border-radius: 4px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.05);
        color: rgba(203, 195, 215, 0.8);
        flex-shrink: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 120px;
    }
    
    .badge-anime {
        background: rgba(208, 188, 255, 0.1);
        border-color: rgba(208, 188, 255, 0.2);
        color: #d0bcff;
    }
    .badge-manga {
        background: rgba(16, 185, 129, 0.1);
        border-color: rgba(16, 185, 129, 0.2);
        color: #6ee7b7;
    }
    .badge-novel {
        background: rgba(245, 158, 11, 0.1);
        border-color: rgba(245, 158, 11, 0.2);
        color: #fcd34d;
    }
    .badge-folder {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.15);
        color: rgba(203, 195, 215, 0.9);
    }
    
    .palette-item-subtitle {
        font-size: 11px;
        color: rgba(203, 195, 215, 0.4);
        margin-top: 2px;
        text-overflow: ellipsis;
        white-space: nowrap;
        overflow: hidden;
        max-width: 100%;
        display: block;
    }
    
    .palette-item-indicator {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        color: #d0bcff;
        opacity: 0.6;
    }
    
    .palette-footer {
        padding: 10px 20px;
        background: rgba(15, 13, 21, 0.4);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        font-size: 12px;
        color: rgba(203, 195, 215, 0.7);
    }
    .palette-footer-actions {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }
    .palette-key {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        background: rgba(255, 255, 255, 0.05);
        padding: 2px 6px;
        border-radius: 4px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
    }
    .palette-footer-hint {
        display: flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
    }
    .palette-no-results {
        padding: 32px;
        text-align: center;
        font-size: 14px;
        color: rgba(203, 195, 215, 0.4);
        width: 100%;
    }

    .palette-load-more {
        width: 100%;
        padding: 10px 12px;
        margin-top: 4px;
        border: 1px dashed rgba(255, 255, 255, 0.15);
        border-radius: 12px;
        background: transparent;
        color: rgba(203, 195, 215, 0.7);
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s ease-out;
    }
    .palette-load-more:hover:not(:disabled) {
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        border-color: rgba(208, 188, 255, 0.3);
    }
    .palette-load-more:disabled {
        cursor: default;
        opacity: 0.6;
    }

    /* Embedded (extension iframe): only shell/backdrop differs — the modal and
       footer chrome match the dashboard Ctrl+P palette. Transparent backdrop +
       no top offset so the iframe can hug the modal over the host page. */
    .palette-wrapper.embedded {
        padding-top: 0;
    }
    .palette-wrapper.embedded .palette-backdrop {
        background: transparent;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
    }
    .palette-wrapper.embedded .palette-modal {
        margin: 0;
        max-width: none;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(12px) scale(0.98);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
    .stagger-item {
        opacity: 0;
        animation: fadeInUp 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>
