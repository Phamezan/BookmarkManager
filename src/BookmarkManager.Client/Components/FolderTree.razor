@using BookmarkManager.Contracts
@using MudBlazor

<MudTreeView T="Guid?"
             Items="@_treeItems"
             Hover="true"
             SelectionMode="SelectionMode.SingleSelection"
             SelectedValue="@_selectedFolderId"
             SelectedValueChanged="@OnSelectedChanged">
     <ItemTemplate Context="item">
        <MudTreeViewItem T="Guid?"
                         Value="@item.Value"
                         Items="@item.Children"
                         Expanded="@item.Expanded"
                         ExpandedChanged="@((bool exp) => OnItemExpandedChanged(item, exp))"
                         CanExpand="@(item.Children?.Count > 0)">
            <BodyContent>
                @{
                    var fi = item as FolderTreeItemData;
                }
                <div class="d-flex align-center folder-drop-target"
                     style="@(item.Value.HasValue && DisabledFolderIds.Contains(item.Value.Value) ? "width: 100%; opacity: 0.45; cursor: not-allowed; pointer-events: none;" : "width: 100%;")"
                     data-drop-target="true"
                     draggable="true"
                     data-drag-type="folder"
                     data-drag-id="@item.Value"
                     @onclick="@(() => OnSelectedChanged(item.Value))"
                     @ondragover:prevent
                     @ondrop="@(() => OnDrop(item.Value))"
                     @ondragstart="@(() => OnFolderDragStart(item.Value))"
                     @oncontextmenu="@((e) => OpenFolderContextMenu(e, item.Value))"
                     @oncontextmenu:preventDefault="true"
                     @oncontextmenu:stopPropagation="true">
                    <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Class="mr-2" Style="@($"color: {FolderColorHelper.GetFolderColor(item.Text ?? string.Empty)};")" />
                    @if (item.Value == _editingItemId)
                    {
                        <input @ref="_editInputRef"
                               type="text"
                               class="folder-inline-input"
                               @bind="_editingItemText"
                               @bind:event="oninput"
                               @onblur="() => CommitCreate(fi)"
                               @onkeyup="(e) => OnEditKeyUp(e, fi)"
                               @onclick:stopPropagation
                               @ondragstart:preventDefault
                               @ondragstart:stopPropagation />
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="flex-grow-1">@item.Text</MudText>
                        @if (fi?.BookmarkCount > 0)
                        {
                            <span class="folder-count-badge">@fi.BookmarkCount</span>
                        }
                        @if (item.Value.HasValue && item.Value.Value != Guid.Empty)
                        {
                            <button class="folder-action-btn add-btn"
                                    @onclick:stopPropagation
                                    @onclick="@(() => StartNewSubfolder(item.Value.Value))"
                                    title="New Subfolder">
                                <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                            </button>
                        }
                    }
                </div>
            </BodyContent>
        </MudTreeViewItem>
    </ItemTemplate>
</MudTreeView>

@code {
    [Parameter] public List<FolderTreeNodeDto> Folders { get; set; } = [];
    [Parameter] public Guid? SelectedFolderId { get; set; }
    [Parameter] public HashSet<Guid> DisabledFolderIds { get; set; } = [];
    [Parameter] public EventCallback<Guid> FolderSelected { get; set; }
    [Parameter] public EventCallback<Guid> FolderDrop { get; set; }
    [Parameter] public EventCallback<Guid> FolderDragStart { get; set; }
    [Parameter] public EventCallback<(MouseEventArgs MouseEvent, Guid FolderId)> FolderContextMenu { get; set; }
    [Parameter] public HashSet<Guid> ExpandedItems { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> ExpandedItemsChanged { get; set; }
    [Parameter] public EventCallback<(Guid ParentId, string Name)> FolderCreated { get; set; }

    private HashSet<Guid> _expandedFolderIds = [];
    private List<TreeItemData<Guid?>> _treeItems = [];
    private Guid? _selectedFolderId;
    private List<FolderTreeNodeDto>? _lastFolders;

    private Guid? _editingItemId;
    private Guid? _editingItemParentId;
    private string _editingItemText = "";
    private bool _focusEditInput;
    private bool _isCommitInProgress;
    private ElementReference _editInputRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusEditInput)
        {
            _focusEditInput = false;
            try
            {
                await _editInputRef.FocusAsync();
            }
            catch
            {
                // Ignored
            }
        }
    }

    private async Task StartNewSubfolder(Guid parentId)
    {
        _expandedFolderIds.Add(parentId);
        await ExpandedItemsChanged.InvokeAsync(_expandedFolderIds);

        var parentItem = FindTreeItemById(_treeItems, parentId);
        if (parentItem != null)
        {
            var tempId = Guid.NewGuid();
            var tempNode = new FolderTreeItemData
            {
                Value = tempId,
                Text = "",
                BookmarkCount = 0,
                Children = []
            };

            var childrenList = parentItem.Children?.ToList() ?? new List<ITreeItemData<Guid?>>();
            childrenList.Add(tempNode);
            parentItem.Children = childrenList;

            _editingItemId = tempId;
            _editingItemParentId = parentId;
            _editingItemText = "";
            _focusEditInput = true;
            StateHasChanged();
        }
    }

    private FolderTreeItemData? FindTreeItemById(IEnumerable<ITreeItemData<Guid?>> items, Guid id)
    {
        foreach (var item in items)
        {
            if (item is FolderTreeItemData fi && fi.Value == id)
                return fi;
            if (item.Children?.Count > 0)
            {
                var found = FindTreeItemById(item.Children, id);
                if (found != null)
                    return found;
            }
        }
        return null;
    }

    private async Task OnEditKeyUp(KeyboardEventArgs e, FolderTreeItemData? item)
    {
        if (e.Key == "Enter")
        {
            await CommitCreate(item);
        }
        else if (e.Key == "Escape")
        {
            CancelCreate(item);
        }
    }

    private async Task CommitCreate(FolderTreeItemData? item)
    {
        if (_isCommitInProgress) return;
        _isCommitInProgress = true;

        try
        {
            if (item == null || string.IsNullOrWhiteSpace(_editingItemText))
            {
                CancelCreate(item);
                return;
            }

            var parentId = _editingItemParentId;
            var name = _editingItemText;

            _editingItemId = null;
            _editingItemParentId = null;
            _editingItemText = "";

            if (parentId.HasValue)
            {
                await FolderCreated.InvokeAsync((parentId.Value, name));
            }
        }
        finally
        {
            _isCommitInProgress = false;
        }
    }

    private void CancelCreate(FolderTreeItemData? item)
    {
        if (item != null && _editingItemParentId.HasValue)
        {
            var parentItem = FindTreeItemById(_treeItems, _editingItemParentId.Value);
            if (parentItem?.Children != null)
            {
                var childrenList = parentItem.Children.ToList();
                childrenList.Remove(item);
                parentItem.Children = childrenList;
            }
        }

        _editingItemId = null;
        _editingItemParentId = null;
        _editingItemText = "";
        StateHasChanged();
    }


    protected override void OnParametersSet()
    {
        _selectedFolderId = SelectedFolderId;
        _expandedFolderIds = ExpandedItems;
        if (Folders != _lastFolders)
        {
            _lastFolders = Folders;
            _treeItems = Folders.Select(ToTreeItemData).Select(x => (TreeItemData<Guid?>)x).ToList();
        }
        else
        {
            SyncExpansionStates(_treeItems, _expandedFolderIds);
        }
    }

    private void SyncExpansionStates(IEnumerable<ITreeItemData<Guid?>> items, HashSet<Guid> expandedIds)
    {
        foreach (var item in items)
        {
            if (item.Value.HasValue)
            {
                item.Expanded = expandedIds.Contains(item.Value.Value);
            }
            if (item.Children?.Count > 0)
            {
                SyncExpansionStates(item.Children, expandedIds);
            }
        }
    }

    private async Task OnItemExpandedChanged(ITreeItemData<Guid?> item, bool expanded)
    {
        item.Expanded = expanded;
        if (item.Value.HasValue)
        {
            var id = item.Value.Value;
            if (expanded)
                _expandedFolderIds.Add(id);
            else
                _expandedFolderIds.Remove(id);

            await ExpandedItemsChanged.InvokeAsync(_expandedFolderIds);
        }
    }

    private void OnSelectedChanged(Guid? id)
    {
        _selectedFolderId = id;
        if (id.HasValue)
            FolderSelected.InvokeAsync(id.Value);
    }

    private async Task OnFolderDragStart(Guid? id)
    {
        if (id.HasValue)
            await FolderDragStart.InvokeAsync(id.Value);
    }

    private async Task OnDrop(Guid? folderId)
    {
        if (folderId.HasValue)
            await FolderDrop.InvokeAsync(folderId.Value);
    }

    private async Task OpenFolderContextMenu(MouseEventArgs e, Guid? id)
    {
        if (id.HasValue)
            await FolderContextMenu.InvokeAsync((e, id.Value));
    }

    private FolderTreeItemData ToTreeItemData(FolderTreeNodeDto dto)
    {
        return new FolderTreeItemData
        {
            Value = dto.Id,
            Text = dto.Title,
            BookmarkCount = dto.BookmarkCount,
            Children = dto.Children.Select(ToTreeItemData).ToList(),
            Expanded = _expandedFolderIds.Contains(dto.Id)
        };
    }

    private class FolderTreeItemData : TreeItemData<Guid?>
    {
        public int BookmarkCount { get; set; }
    }
}
