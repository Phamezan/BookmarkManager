@* Design 2a — month grid. Six week-rows for the anchor's month; leading/trailing
   days dimmed. Days with episodes show small cover-image badges (one per series,
   overflow collapsed to "+N") so the month reads as a visual overview. Hovering a
   badge pops up a bigger cover + title + episode + ticking dd:hh:mm:ss countdown;
   clicking a populated day opens its full Day view. *@
@implements IDisposable

<div class="acal-month-grid">
    @foreach (var name in DayHeaders)
    {
        <div class="acal-month-head">@name</div>
    }
    @foreach (var cell in _cells)
    {
        <div class="@CellClass(cell)" @onclick="() => OpenDay(cell)">
            <div class="acal-month-daynum">@cell.Date.Day.ToString("00")</div>
            @if (cell.Count > 0)
            {
                <div class="acal-month-events">
                    @foreach (var item in cell.Visible)
                    {
                        <div class="acal-month-event" @onclick:stopPropagation="true" @onclick="() => OnItemClick.InvokeAsync(item)">
                            <CoverPoster CoverImageUrl="@item.CoverImageUrl" Title="@item.Title"
                                         Width="16px" Height="22px" CssClass="acal-month-cover-mini" />
                            <span class="acal-event-title-text">@item.Title</span>
                            <span class="acal-event-ep-text">@item.EpisodeNumber</span>

                            <div class="rich-tip">
                                <CoverPoster CoverImageUrl="@item.CoverImageUrl" Title="@item.Title"
                                             Width="160px" Height="224px" CssClass="acal-tip-cover" />
                                <div class="acal-tip-details">
                                    <div class="acal-tip-title">@item.Title</div>
                                    <div class="acal-tip-ep">Episode @item.EpisodeNumber</div>
                                    <div class="acal-tip-time">Airing @item.AiringAtLocal.ToString("h:mm tt")</div>
                                    <div class="acal-tip-countdown">@item.CountdownText</div>
                                </div>
                            </div>
                        </div>
                    }
                    @if (cell.Overflow > 0)
                    {
                        <div class="acal-event-more">+@cell.Overflow more</div>
                    }
                </div>
            }
            else
            {
                <div class="acal-month-empty">—</div>
            }
        </div>
    }
</div>

<div class="acal-month-footer">@_totalEpisodes episode@(_totalEpisodes == 1 ? "" : "s") airing this month</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<AnimeCalendarItem> Items { get; set; } = [];
    [Parameter] public DateTime Anchor { get; set; } = DateTime.Today;
    [Parameter] public EventCallback<AnimeCalendarItem> OnItemClick { get; set; }
    [Parameter] public EventCallback<DateOnly> OnDaySelected { get; set; }

    private static readonly string[] DayHeaders = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

    // How many cover badges fit a cell before collapsing the rest into "+N".
    private const int MaxCovers = 3;

    private List<Cell> _cells = [];
    private int _totalEpisodes;
    private Timer? _countdownTicker;

    protected override void OnInitialized()
    {
        // Only the hovered popover's countdown is visible at once, but ticking here
        // (rather than per-item) keeps whichever one is open live to the second.
        _countdownTicker = new Timer(_ => InvokeAsync(StateHasChanged), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    public void Dispose() => _countdownTicker?.Dispose();

    protected override void OnParametersSet()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var first = new DateOnly(Anchor.Year, Anchor.Month, 1);
        var gridStart = first.AddDays(-(int)first.DayOfWeek); // back up to the Sunday

        // Count episodes per day within the visible month; drive both cell badges
        // and the footer total off the same in-month tally.
        var perDay = Items
            .Where(i => i.AiringDay.Year == Anchor.Year && i.AiringDay.Month == Anchor.Month)
            .GroupBy(i => i.AiringDay)
            .ToDictionary(
                g => g.Key,
                // One badge per series per day (the user bookmarks per-episode, so the
                // same show can appear multiple times); keep the earliest airing of each.
                g => g.OrderBy(i => i.AiringAtLocal)
                      .GroupBy(i => i.SeriesKey)
                      .Select(s => s.First())
                      .ToList());

        _totalEpisodes = perDay.Values.Sum(v => v.Count);

        _cells = Enumerable.Range(0, 42).Select(offset =>
        {
            var date = gridStart.AddDays(offset);
            var inMonth = date.Month == Anchor.Month && date.Year == Anchor.Year;
            var items = inMonth && perDay.TryGetValue(date, out var list) ? list : [];
            return new Cell(date, inMonth, date == today, items);
        }).ToList();
    }

    private Task OpenDay(Cell cell)
        => cell.Count > 0 ? OnDaySelected.InvokeAsync(cell.Date) : Task.CompletedTask;

    private static string CellClass(Cell cell)
    {
        var cls = "acal-month-cell";
        if (!cell.InMonth) cls += " is-outside";
        if (cell.Count > 0) cls += " is-populated";
        if (cell.IsToday) cls += " is-today";
        return cls;
    }

    private sealed record Cell(DateOnly Date, bool InMonth, bool IsToday, List<AnimeCalendarItem> Items)
    {
        public int Count => Items.Count;
        public IEnumerable<AnimeCalendarItem> Visible => Items.Take(MaxCovers);
        public int Overflow => Math.Max(0, Items.Count - MaxCovers);
    }
}
