@* Designs 1d + 2b merged — violet roadmap: the anchor's week grouped by day as a
   connected vertical timeline. Only days that actually have episodes get a node;
   today's node/label render in amber. *@

@if (_days.Count == 0)
{
    <div class="acal-empty">Nothing airing this week.</div>
}
else
{
    <div class="acal-timeline">
        <div class="acal-timeline-rail"></div>
        @foreach (var day in _days)
        {
            var isToday = day.Date == _today;
            <div class="acal-timeline-group">
                <span class="acal-timeline-node@(isToday ? " is-today" : "")"></span>
                <div class="acal-timeline-daylabel@(isToday ? " is-today" : "")">
                    @day.Date.ToString("ddd dd").ToUpperInvariant()@(isToday ? " · TODAY" : "")
                </div>
                <div class="acal-timeline-cards">
                    @foreach (var item in day.Items)
                    {
                        <EpisodeCard Item="item" OnClick="OnItemClick" Emphasized="isToday" />
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<AnimeCalendarItem> Items { get; set; } = [];
    [Parameter] public DateTime Anchor { get; set; } = DateTime.Today;
    [Parameter] public EventCallback<AnimeCalendarItem> OnItemClick { get; set; }

    private DateOnly _today;
    private List<DayGroup> _days = [];

    protected override void OnParametersSet()
    {
        _today = DateOnly.FromDateTime(DateTime.Today);
        var weekStart = DateOnly.FromDateTime(Anchor.AddDays(-(int)Anchor.DayOfWeek));
        var weekEnd = weekStart.AddDays(6);

        _days = Items
            .Where(i => i.AiringDay >= weekStart && i.AiringDay <= weekEnd)
            .GroupBy(i => i.AiringDay)
            .OrderBy(g => g.Key)
            .Select(g => new DayGroup(g.Key, g.OrderBy(i => i.AiringAtLocal).ToList()))
            .ToList();
    }

    private sealed record DayGroup(DateOnly Date, List<AnimeCalendarItem> Items);
}
