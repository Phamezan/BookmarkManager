@using BookmarkManager.Contracts
@using BookmarkManager.Client.Features.Bookmarks
@using Microsoft.AspNetCore.Components.Web
@implements IDisposable

<div @oncontextmenu="@((MouseEventArgs e) => ContextMenuOpened(e, Item))" @oncontextmenu:preventDefault="true"
     @oncontextmenu:stopPropagation="true" style="display: contents;">
    <div id="bookmark-card-@Item.Id" class="@($"bookmark-card {(IsSelected ? "is-selected" : "")} {(IsFocused ? "is-focused" : "")}")" role="listitem"
         draggable="true" data-drag-type="bookmark" data-drag-id="@Item.Id"
         @ondragstart="@(() => DragStarted(Item.Id))" @onclick="@((MouseEventArgs e) => RowClicked(e, Item))"
         @onmouseenter="OnCardMouseEnter" @onmouseleave="OnCardMouseLeave">
        <div class="bookmark-select" @onclick:stopPropagation>
            <input type="checkbox" checked="@IsSelected"
                   @onclick="@((MouseEventArgs e) => CheckboxClicked(e, Item.Id))" class="bm-checkbox"
                   aria-label="@($"Select {Item.Title}")" />
        </div>

        <div class="bookmark-card-header">
            <div class="bookmark-card-title-group">
                <div class="bookmark-card-icon">
                    @if (Item.Type == NodeType.Folder)
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="@($"color: {FolderColorHelper.GetFolderColor(Item.Title)};")"><path d="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z"/></svg>
                    }
                    else if (!string.IsNullOrEmpty(Item.CoverImageUrl))
                    {
                        <img src="@Item.CoverImageUrl" alt="" class="cover-image" onerror="this.style.display='none'" />
                    }
                    else if (!string.IsNullOrEmpty(Item.Url))
                    {
                        var faviconUrl = GetFaviconUrl(Item.Url);
                        @if (faviconUrl != null)
                        {
                            <img src="@faviconUrl" alt="" width="16" height="16" onerror="this.style.display='none'" />
                        }
                        else
                        {
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2z"/></svg>
                        }
                    }
                </div>
                <h3 class="bookmark-card-title" title="@Item.Title">
                    @if (Item.Type != NodeType.Folder && !string.IsNullOrEmpty(Item.Url))
                    {
                        <a href="@Item.Url" target="_blank" rel="noopener noreferrer" tabindex="-1" @onclick:stopPropagation>@Item.Title</a>
                    }
                    else
                    {
                        <span>@Item.Title</span>
                    }
                    @if (Item.Metadata?.IsFavorite == true)
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="color: #fbbf24; margin-left: 6px; vertical-align: middle;"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                    }
                </h3>
            </div>
        </div>

        @if (Item.Type != NodeType.Folder && !string.IsNullOrEmpty(Item.Url))
        {
            <a href="@Item.Url" target="_blank" class="bookmark-card-url" title="@Item.Url" tabindex="-1" @onclick:stopPropagation>@GetDisplayUrl(Item.Url)</a>
        }

        <div class="bookmark-card-footer">
            <div class="bookmark-card-footer-left">
                <div class="bookmark-card-tags">
                    @if (!string.IsNullOrEmpty(Item.MediaStatus))
                    {
                        <span class="status-badge @GetMediaStatusClass(Item.MediaStatus)" style="padding: 2px 6px; font-size: 0.66rem; line-height: 1.2;">@GetMediaStatusLabel(Item.MediaStatus)</span>
                    }
                    @if (string.Equals(Item.Metadata?.Status, BookmarkReadingStatus.PlanToRead, StringComparison.Ordinal))
                    {
                        <span class="status-badge status-badge--active" style="padding: 2px 6px; font-size: 0.66rem; line-height: 1.2;">Later</span>
                    }
                    @if (Item.Metadata?.Category != null)
                    {
                        <span class="tag-badge">@Item.Metadata.Category</span>
                    }
                    @if (Item.Metadata?.Tags != null)
                    {
                        @foreach (var tag in Item.Metadata.Tags.Take(2))
                        {
                            <span class="tag-badge">@tag</span>
                        }
                    }
                </div>
                @{
                    var folderPath = Item.Type == NodeType.Folder
                        ? GetFolderPath(Item.ParentId)
                        : GetParentFolderName(Item.ParentId);
                }
                @if (!string.IsNullOrEmpty(folderPath))
                {
                    <span class="bookmark-card-folder-path" title="@folderPath">@folderPath</span>
                }
            </div>
            <span class="bookmark-card-time">@FormatUpdatedAt(Item.UpdatedAt)</span>
        </div>

        <div class="bookmark-card-actions" @onclick:stopPropagation>
            <button class="bm-icon-btn @(Item.Metadata?.IsFavorite == true ? "btn-active" : "")" title="@(Item.Metadata?.IsFavorite == true ? "Remove from Favorites" : "Add to Favorites")" @onclick="@(() => ToggleFavoriteAsync(Item))" type="button">
                @if (Item.Metadata?.IsFavorite == true)
                {
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                }
                else
                {
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                }
            </button>
            @if (Item.Type == NodeType.Folder)
            {
                <button class="bm-icon-btn" title="Move folder" @onclick="@(() => MoveFolderAsync(Item.Id))" aria-label="@($"Move {Item.Title}")" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-6 12v-3h-4v-3h4V8l5 5-5 5z"/></svg>
                </button>
                <button class="bm-icon-btn btn-error" title="Delete folder" @onclick="@(() => DeleteFolderAsync(Item.Id))" aria-label="@($"Delete {Item.Title}")" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                </button>
            }
            else
            {
                <button class="bm-icon-btn" title="Edit fields" @onclick="@(() => EditBookmarkAsync(Item))" aria-label="@($"Edit {Item.Title}")" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                </button>
                <button class="bm-icon-btn" title="Move bookmark" @onclick="@(() => MoveBookmarkAsync(Item))" aria-label="@($"Move {Item.Title}")" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-6 12v-3h-4v-3h4V8l5 5-5 5z"/></svg>
                </button>
                <button class="bm-icon-btn btn-error" title="Delete bookmark" @onclick="@(() => DeleteBookmarkAsync(Item))" aria-label="@($"Delete {Item.Title}")" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                </button>
            }
        </div>

        <MudPopover Open="_previewOpen" Fixed="true" AnchorOrigin="Origin.TopCenter" TransformOrigin="Origin.BottomCenter"
                    OverflowBehavior="OverflowBehavior.FlipOnOpen" Class="bookmark-preview-popover" Style="pointer-events: none;">
            <div class="bookmark-preview-content">
                @{
                    var previewCoverUrl = Item.CoverImageUrl ?? Item.Metadata?.CoverImageUrl;
                    var previewFaviconUrl = string.IsNullOrEmpty(previewCoverUrl) && !string.IsNullOrEmpty(Item.Url)
                        ? GetFaviconUrl(Item.Url)
                        : null;
                }
                @if (!string.IsNullOrEmpty(previewCoverUrl))
                {
                    <img src="@previewCoverUrl" alt="" class="bookmark-preview-cover" onerror="this.style.display='none'" />
                }
                else if (!string.IsNullOrEmpty(previewFaviconUrl))
                {
                    <div class="bookmark-preview-cover bookmark-preview-cover--favicon">
                        <img src="@previewFaviconUrl" alt="" onerror="this.parentElement.style.display='none'" />
                    </div>
                }
                <div class="bookmark-preview-title">@Item.Title</div>
                @if (Item.Type != NodeType.Folder && !string.IsNullOrEmpty(Item.Url))
                {
                    <div class="bookmark-preview-url">@Item.Url</div>
                }
                @{
                    var previewTags = GetPreviewTags(Item);
                }
                @if (previewTags.Count > 0)
                {
                    <div class="bookmark-preview-tags">
                        @foreach (var tag in previewTags)
                        {
                            <span class="tag-badge">@tag</span>
                        }
                    </div>
                }
                <div class="bookmark-preview-meta">Updated @FormatUpdatedAt(Item.UpdatedAt) (@Item.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))</div>
                @{
                    var previewFolderPath = GetFolderPath(Item.ParentId);
                }
                @if (!string.IsNullOrEmpty(previewFolderPath))
                {
                    <div class="bookmark-preview-folder">@previewFolderPath</div>
                }
            </div>
        </MudPopover>
    </div>
</div>

@code {
    private const int PreviewHoverDelayMs = 400;

    private CancellationTokenSource? _previewCts;
    private bool _previewOpen;

    [Parameter, EditorRequired] public BookmarkNodeDto Item { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsFocused { get; set; }
    [Parameter] public Func<string, string?> GetFaviconUrl { get; set; } = _ => null;
    [Parameter] public Func<Guid?, string> GetParentFolderName { get; set; } = _ => string.Empty;
    [Parameter] public Func<Guid?, string> GetFolderPath { get; set; } = _ => string.Empty;
    [Parameter] public Func<DateTime, string> FormatUpdatedAt { get; set; } = _ => string.Empty;
    [Parameter] public Func<MouseEventArgs, BookmarkNodeDto, Task> RowClicked { get; set; } = (_, _) => Task.CompletedTask;
    [Parameter] public Action<MouseEventArgs, Guid> CheckboxClicked { get; set; } = (_, _) => { };
    [Parameter] public Action<MouseEventArgs, BookmarkNodeDto> ContextMenuOpened { get; set; } = (_, _) => { };
    [Parameter] public Action<Guid> DragStarted { get; set; } = _ => { };
    [Parameter] public Func<BookmarkNodeDto, Task> ToggleFavoriteAsync { get; set; } = _ => Task.CompletedTask;
    [Parameter] public Func<BookmarkNodeDto, Task> EditBookmarkAsync { get; set; } = _ => Task.CompletedTask;
    [Parameter] public Func<BookmarkNodeDto, Task> MoveBookmarkAsync { get; set; } = _ => Task.CompletedTask;
    [Parameter] public Func<BookmarkNodeDto, Task> DeleteBookmarkAsync { get; set; } = _ => Task.CompletedTask;
    [Parameter] public Func<Guid, Task> MoveFolderAsync { get; set; } = _ => Task.CompletedTask;
    [Parameter] public Func<Guid, Task> DeleteFolderAsync { get; set; } = _ => Task.CompletedTask;

    private static string GetDisplayUrl(string url)
    {
        if (string.IsNullOrEmpty(url)) return string.Empty;
        try
        {
            var uri = new Uri(url);
            var host = uri.Host;
            if (host.StartsWith("www."))
            {
                host = host.Substring(4);
            }
            return host;
        }
        catch
        {
            return url;
        }
    }

    private static string GetMediaStatusClass(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return string.Empty;
        return status.ToUpperInvariant() switch
        {
            "HIATUS" => "status-badge--warning",
            "CANCELLED" or "DROPPED" => "status-badge--danger",
            "FINISHED" or "COMPLETED" => "status-badge--success",
            "RELEASING" or "ONGOING" => "status-badge--watching",
            "NOT_YET_RELEASED" or "UPCOMING" => "status-badge--active",
            _ => "status-badge--favorite"
        };
    }

    private static string GetMediaStatusLabel(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return string.Empty;
        return status.ToUpperInvariant() switch
        {
            "HIATUS" => "Hiatus",
            "CANCELLED" or "DROPPED" => "Dropped",
            "FINISHED" or "COMPLETED" => "Completed",
            "RELEASING" or "ONGOING" => "Ongoing",
            "NOT_YET_RELEASED" or "UPCOMING" => "Upcoming",
            _ => status
        };
    }

    private static List<string> GetPreviewTags(BookmarkNodeDto item)
    {
        var tags = new List<string>();
        if (!string.IsNullOrEmpty(item.Metadata?.Category))
        {
            tags.Add(item.Metadata.Category);
        }
        if (item.Metadata?.Tags != null)
        {
            tags.AddRange(item.Metadata.Tags);
        }
        return tags;
    }

    protected override void OnInitialized()
    {
        BookmarkPreviewCoordinator.DismissRequested += OnDismissPreview;
        BookmarkPreviewCoordinator.ToggleRequested += OnTogglePreview;
    }

    /// <summary>Handles the "i" keyboard shortcut (<c>Bookmarks.Keyboard.cs</c>) — only the
    /// focused card's id matches, every other subscribed card ignores the request.</summary>
    private void OnTogglePreview(Guid id)
    {
        if (id != Item.Id) return;

        if (_previewOpen)
        {
            ClosePreview();
        }
        else
        {
            CancelPendingPreview();
            _previewOpen = true;
            BookmarkPreviewCoordinator.NotifyOpened();
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private void OnCardMouseEnter()
    {
        CancelPendingPreview();
        var cts = new CancellationTokenSource();
        _previewCts = cts;
        _ = OpenPreviewAfterDelayAsync(cts);
    }

    private void OnCardMouseLeave()
    {
        CancelPendingPreview();
        ClosePreview();
    }

    private async Task OpenPreviewAfterDelayAsync(CancellationTokenSource cts)
    {
        try
        {
            await Task.Delay(PreviewHoverDelayMs, cts.Token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        if (cts.IsCancellationRequested) return;
        _previewOpen = true;
        BookmarkPreviewCoordinator.NotifyOpened();
        await InvokeAsync(StateHasChanged);
    }

    private void CancelPendingPreview()
    {
        _previewCts?.Cancel();
        _previewCts?.Dispose();
        _previewCts = null;
    }

    private void ClosePreview()
    {
        if (!_previewOpen) return;
        _previewOpen = false;
        BookmarkPreviewCoordinator.NotifyClosed();
        StateHasChanged();
    }

    private void OnDismissPreview()
    {
        var hadPendingOrOpen = _previewCts != null || _previewOpen;
        if (!hadPendingOrOpen) return;

        CancelPendingPreview();
        if (_previewOpen)
        {
            _previewOpen = false;
            BookmarkPreviewCoordinator.NotifyClosed();
        }
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        BookmarkPreviewCoordinator.DismissRequested -= OnDismissPreview;
        BookmarkPreviewCoordinator.ToggleRequested -= OnTogglePreview;
        CancelPendingPreview();
        if (_previewOpen)
        {
            _previewOpen = false;
            BookmarkPreviewCoordinator.NotifyClosed();
        }
    }
}
