@using BookmarkManager.Contracts
@using Microsoft.AspNetCore.Components.Web
@implements IAsyncDisposable
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<div class="bookmark-list" @ref="_gridContainerRef">
    @if (Loading)
    {
        <div class="bookmark-grid" aria-label="Loading bookmarks...">
            @for (int i = 0; i < 6; i++)
            {
                <div class="skeleton-card" />
            }
        </div>
    }
    else if (Items.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon-wrap" aria-hidden="true">
                <MudIcon Icon="@(string.IsNullOrWhiteSpace(SearchQuery) ? Icons.Material.Filled.FolderOpen : Icons.Material.Filled.SearchOff)" />
            </div>
            <div class="empty-state-copy">
                <MudText Typo="Typo.h6" Class="empty-state-title">
                    @(string.IsNullOrWhiteSpace(SearchQuery) ? "No bookmarks to show" : "No matches found")
                </MudText>
                <MudText Typo="Typo.body2" Class="empty-state-sub">
                    @(string.IsNullOrWhiteSpace(SearchQuery)
                        ? "Pick a folder on the left, or create your first bookmark to get started."
                        : "Try a different keyword, or clear the filters above.")
                </MudText>
            </div>
            @if (string.IsNullOrWhiteSpace(SearchQuery))
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddLink"
                           OnClick="CreateBookmark" Class="empty-state-cta">
                    New Bookmark
                </MudButton>
            }
        </div>
    }
    else
    {
        <Virtualize Items="@_rows" Context="row" ItemSize="154" OverscanCount="8">
            <div class="bookmark-grid" role="list" aria-label="Bookmarks">
                @foreach (var item in row)
                {
                    <BookmarkCard @key="item.Id"
                                  Item="item"
                                  IsSelected="IsSelected(item.Id)"
                                  GetFaviconUrl="GetFaviconUrl"
                                  GetParentFolderName="GetParentFolderName"
                                  GetFolderPath="GetFolderPath"
                                  FormatUpdatedAt="FormatUpdatedAt"
                                  RowClicked="RowClicked"
                                  CheckboxClicked="CheckboxClicked"
                                  ContextMenuOpened="ContextMenuOpened"
                                  DragStarted="DragStarted"
                                  ToggleFavoriteAsync="ToggleFavoriteAsync"
                                  EditBookmarkAsync="EditBookmarkAsync"
                                  MoveBookmarkAsync="MoveBookmarkAsync"
                                  DeleteBookmarkAsync="DeleteBookmarkAsync"
                                  MoveFolderAsync="MoveFolderAsync"
                                  DeleteFolderAsync="DeleteFolderAsync" />
                }
            </div>
        </Virtualize>
    }
</div>

@code {
    private const int MinCardWidthPx = 280;
    private const int GapPx = 12;

    private ElementReference _gridContainerRef;
    private Microsoft.JSInterop.IJSObjectReference? _resizeObserver;
    private Microsoft.JSInterop.DotNetObjectReference<BookmarkList>? _dotNetRef;
    private int _columns = 3;

    [Parameter] public bool Loading { get; set; }
    [Parameter] public List<BookmarkNodeDto> Items { get; set; } = [];
    [Parameter] public string SearchQuery { get; set; } = string.Empty;
    [Parameter] public EventCallback CreateBookmark { get; set; }
    [Parameter] public Func<Guid, bool> IsSelected { get; set; } = _ => false;
    [Parameter] public Func<string, string?> GetFaviconUrl { get; set; } = _ => null;
    [Parameter] public Func<Guid?, string> GetParentFolderName { get; set; } = _ => string.Empty;
    [Parameter] public Func<Guid?, string> GetFolderPath { get; set; } = _ => string.Empty;
    [Parameter] public Func<DateTime, string> FormatUpdatedAt { get; set; } = _ => string.Empty;
    [Parameter] public Func<MouseEventArgs, BookmarkNodeDto, Task> RowClicked { get; set; } = (_, _) => Task.CompletedTask;
    [Parameter] public Action<MouseEventArgs, Guid> CheckboxClicked { get; set; } = (_, _) => { };
    [Parameter] public Action<MouseEventArgs, BookmarkNodeDto> ContextMenuOpened { get; set; } = (_, _) => { };
    [Parameter] public Action<Guid> DragStarted { get; set; } = _ => { };
    [Parameter] public Func<BookmarkNodeDto, Task> ToggleFavoriteAsync { get; set; } = _ => Task.CompletedTask;
    [Parameter] public Func<BookmarkNodeDto, Task> EditBookmarkAsync { get; set; } = _ => Task.CompletedTask;
    [Parameter] public Func<BookmarkNodeDto, Task> MoveBookmarkAsync { get; set; } = _ => Task.CompletedTask;
    [Parameter] public Func<BookmarkNodeDto, Task> DeleteBookmarkAsync { get; set; } = _ => Task.CompletedTask;
    [Parameter] public Func<Guid, Task> MoveFolderAsync { get; set; } = _ => Task.CompletedTask;
    [Parameter] public Func<Guid, Task> DeleteFolderAsync { get; set; } = _ => Task.CompletedTask;

    private List<BookmarkNodeDto[]> _rows = [];
    private List<BookmarkNodeDto>? _lastItems;
    private int _lastColumns;

    protected override void OnParametersSet()
    {
        UpdateRows();
    }

    private void UpdateRows()
    {
        if (_lastItems != null && Items == _lastItems && _columns == _lastColumns)
            return;

        _lastItems = Items;
        _lastColumns = _columns;
        _rows = Items.OrderBy(i => i.Type == NodeType.Folder ? 0 : 1)
                     .Chunk(Math.Max(1, _columns))
                     .ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _dotNetRef = Microsoft.JSInterop.DotNetObjectReference.Create(this);
                _columns = await JSRuntime.InvokeAsync<int>("BookmarkGridInterop.getColumnCount", _gridContainerRef, MinCardWidthPx, GapPx);
                _resizeObserver = await JSRuntime.InvokeAsync<Microsoft.JSInterop.IJSObjectReference>(
                    "BookmarkGridInterop.observeResize", _gridContainerRef, _dotNetRef, MinCardWidthPx, GapPx);
                UpdateRows();
                StateHasChanged();
                await JSRuntime.InvokeVoidAsync("initBookmarkGridBloom", ".bookmark-grid");
            }
            catch
            {
                // Safe fallback during unmounting
            }
        }

        // Re-run on every render — animateBookmarkGrid keys off the visible
        // card ids and no-ops when the grid content hasn't actually changed.
        try
        {
            await JSRuntime.InvokeVoidAsync("animateBookmarkGrid", ".bookmark-grid");
        }
        catch
        {
            // Safe fallback during unmounting
        }
    }

    [Microsoft.JSInterop.JSInvokable]
    public void OnColumnsChanged(int columns)
    {
        try
        {
            columns = Math.Max(1, columns);
            if (columns == _columns) return;
            _columns = columns;
            UpdateRows();
            StateHasChanged();
        }
        catch
        {
            // Safe fallback
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_resizeObserver is not null)
        {
            try
            {
                await _resizeObserver.InvokeVoidAsync("disconnect");
                await _resizeObserver.DisposeAsync();
            }
            catch
            {
                // Safe fallback during dispose
            }
        }
        _dotNetRef?.Dispose();
    }
}
