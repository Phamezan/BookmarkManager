<div class="extension-offline-container">
    <div class="extension-offline-card">
        <MudIcon Icon="@Icons.Material.Filled.CloudOff" Class="extension-offline-icon" />
        <MudText Typo="Typo.h5" Class="extension-offline-title">Extension is Offline</MudText>
        <MudText Typo="Typo.body1" Class="extension-offline-desc">
            The Brave extension is not connected or responsive.
            Please pair the extension and ensure it is running to sync and manage your bookmarks.
        </MudText>
        <MudText Typo="Typo.caption" Class="extension-offline-help">
            Commands are queued until the extension checks in. Check settings to verify connections.
        </MudText>
    </div>
</div>
