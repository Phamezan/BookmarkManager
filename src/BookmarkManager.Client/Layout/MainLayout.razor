@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="true" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<canvas id="bg-canvas"></canvas>

<MudLayout Class="app-shell">
    <MudAppBar Elevation="0" Class="app-topbar">
        <NavMenu />
        <MudSpacer />
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="topbar-status">
            <MudTooltip
                Text="@(_extensionService.IsConnected ? "Extension is connected and responsive." : "Commands are queued until the extension checks in.")">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         Color="@(_extensionService.IsConnected ? Color.Success : Color.Warning)"
                         Icon="@(_extensionService.IsConnected ? Icons.Material.Filled.CloudDone : Icons.Material.Filled.CloudOff)">
                    <span class="status-dot @( _extensionService.IsConnected ? "is-online" : "is-offline")"
                          aria-hidden="true"></span>
                    @(_extensionService.IsConnected ? "Connected" : "Extension offline")
                </MudChip>
            </MudTooltip>
        </MudStack>
    </MudAppBar>

    <MudMainContent Class="app-main">
        <div class="app-content">
            @if (!_extensionService.IsConnected)
            {
                <div class="extension-offline-container">
                    <div class="extension-offline-card">
                        <div class="extension-offline-icon-wrap" aria-hidden="true">
                            <MudIcon Icon="@Icons.Material.Filled.CloudOff" Class="extension-offline-icon" />
                        </div>
                        <MudText Typo="Typo.h5" Class="extension-offline-title">Extension is Offline</MudText>
                        <MudText Typo="Typo.body1" Class="extension-offline-desc">
                            The Brave extension isn't connected or responsive. Pair it and confirm it's running to sync and
                            manage your bookmarks.
                        </MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Settings" Href="settings" Class="extension-offline-cta">
                            Open Settings
                        </MudButton>
                        <MudText Typo="Typo.caption" Class="extension-offline-help">
                            Commands are queued until the extension checks in.
                        </MudText>
                    </div>
                </div>
            }
            else
            {
                @Body
            }
        </div>
    </MudMainContent>
</MudLayout>

@implements IDisposable

@code {
    [Inject]
    private IExtensionConnectionService _extensionService { get; set; } = null!;

    [Inject]
    private Microsoft.JSInterop.IJSRuntime JSRuntime { get; set; } = null!;

    protected override void OnInitialized()
    {
        _extensionService.ConnectionStateChanged += OnConnectionStateChanged;
        _extensionService.PollAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("initBgShader");
            }
            catch
            {
                // Fallback
            }
        }
    }

    private void OnConnectionStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        _extensionService.ConnectionStateChanged -= OnConnectionStateChanged;
    }
}
