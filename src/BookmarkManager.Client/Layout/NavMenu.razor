@implements IDisposable
@inject NavigationManager Nav
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<div class="nav-3d-stage">
<MudNavMenu Class="primary-nav" Dense="true">
    <div class="nav-active-indicator" aria-hidden="true">
        <div class="nav-active-indicator-disc"></div>
    </div>
    <MudNavLink Href="bookmarks" Ripple="false">
        <span class="nav-link-inner">
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M4 11h16v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                <path d="M4 11V8a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3v3" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                <path d="M12 11v3" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <circle cx="12" cy="15" r="1" fill="currentColor" />
                <path d="M7 5v16M17 5v16" stroke="currentColor" stroke-width="1.2" stroke-dasharray="1 2" />
            </svg>
            Bookmarks
        </span>
    </MudNavLink>
    <MudNavLink Href="recommendations" Ripple="false">
        <span class="nav-link-inner">
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="11" r="7" stroke="currentColor" stroke-width="1.6" />
                <circle cx="12" cy="11" r="5" stroke="currentColor" stroke-width="1" stroke-dasharray="1 2" />
                <path d="M12 7l1.5 4H10.5L12 7ZM12 15l-1.5-4h3L12 15Z" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linejoin="round" />
                <path d="M8 20h8M12 18v2M5 11a7 7 0 0 0 14 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
            </svg>
            Recommendations
        </span>
    </MudNavLink>
    <MudNavLink Href="anime-calendar" Ripple="false">
        <span class="nav-link-inner">
            <img src="wanted_calendar.png" alt="" class="nav-icon-img nav-wanted-poster" />
            Anime Calendar
        </span>
    </MudNavLink>
    <MudNavLink Href="recycle-bin" Ripple="false">
        <span class="nav-link-inner">
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M7 4h10M7 20h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                <path d="M7 4c-2 4-2 12 0 16M17 4c2 4 2 12 0 16" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                <path d="M12 4c-1 4-1 12 0 16" stroke="currentColor" stroke-width="1.2" />
                <path d="M5.5 9h13M5.5 15h13" stroke="currentColor" stroke-width="1.6" />
            </svg>
            Recycle Bin
        </span>
    </MudNavLink>
    <MudNavLink Href="url-migrator" Ripple="false">
        <span class="nav-link-inner">
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 5v13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                <circle cx="12" cy="4" r="2" stroke="currentColor" stroke-width="1.6" />
                <path d="M8 8h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                <path d="M6 13c0 4 3 7 6 7s6-3 6-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                <path d="M5 13l2-1M19 13l-2-1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            </svg>
            URL Migrator
        </span>
    </MudNavLink>
    <MudNavLink Href="settings" Ripple="false">
        <span class="nav-link-inner">
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="12" r="6" stroke="currentColor" stroke-width="1.6" />
                <circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.6" />
                <path d="M12 4v16M4 12h16M6.34 6.34l11.32 11.32M6.34 17.66L17.66 6.34" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1" />
            </svg>
            Settings
        </span>
    </MudNavLink>
</MudNavMenu>
</div>

@code {
    // Icons8 CDN trial. Change to try other looks: doodle, clouds, stickers, plasticine, bubbles, cute-clipart.
    // Not every icon name exists in every style; second argument is the fallback name.
    private const string IconStyle = "doodle";

    private static readonly HashSet<string> MissingInDoodle = new() { "bookmark" };

    private static string IconUrl(string name, string? fallback = null)
    {
        if (fallback is not null && IconStyle == "doodle" && MissingInDoodle.Contains(name))
            name = fallback;
        return $"https://img.icons8.com/{IconStyle}/96/{name}.png";
    }

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("initNavIndicator");
            }
            catch
            {
                // Fallback
            }
        }
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("repositionNavIndicator");
        }
        catch
        {
            // Fallback
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
