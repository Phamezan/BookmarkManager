@implements IDisposable
@inject NavigationManager Nav
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<div class="nav-3d-stage">
<MudNavMenu Class="primary-nav" Dense="true">
    <div class="nav-active-indicator" aria-hidden="true">
        <div class="nav-active-indicator-disc"></div>
    </div>
    <MudNavLink Href="bookmarks" Ripple="false">
        <span class="nav-link-inner">
            <img class="nav-mascot" src="assets/anime/nav/nav-bookmarks.webp" alt="" aria-hidden="true" />
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
            </svg>
            <span class="nav-link-text">Bookmarks</span>
        </span>
    </MudNavLink>
    <MudNavLink Href="recommendations" Ripple="false">
        <span class="nav-link-inner">
            <img class="nav-mascot" src="assets/anime/nav/nav-recommendations.webp" alt="" aria-hidden="true" />
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
            </svg>
            <span class="nav-link-text">Recommendations</span>
        </span>
    </MudNavLink>
    <MudNavLink Href="library" Ripple="false">
        <span class="nav-link-inner">
            <img class="nav-mascot" src="assets/anime/nav/nav-library.webp" alt="" aria-hidden="true" />
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
            <span class="nav-link-text">Library</span>
        </span>
    </MudNavLink>
    <MudNavLink Href="anime-calendar" Ripple="false">
        <span class="nav-link-inner">
            <img class="nav-mascot" src="assets/anime/nav/nav-calendar.webp" alt="" aria-hidden="true" />
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <span class="nav-link-text">Calendar</span>
        </span>
    </MudNavLink>
    <MudNavLink Href="recycle-bin" Ripple="false">
        <span class="nav-link-inner">
            <img class="nav-mascot" src="assets/anime/nav/nav-recycle.webp" alt="" aria-hidden="true" />
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
            </svg>
            <span class="nav-link-text">Recycle Bin</span>
        </span>
    </MudNavLink>
    <MudNavLink Href="url-migrator" Ripple="false">
        <span class="nav-link-inner">
            <img class="nav-mascot" src="assets/anime/nav/nav-url.webp" alt="" aria-hidden="true" />
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="17 1 21 5 17 9"/>
                <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
                <polyline points="7 23 3 19 7 15"/>
                <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
            </svg>
            <span class="nav-link-text">URL Migrator</span>
        </span>
    </MudNavLink>
    <MudNavLink Href="backups" Ripple="false">
        <span class="nav-link-inner">
            <img class="nav-mascot" src="assets/anime/nav/nav-backups.webp" alt="" aria-hidden="true" />
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <ellipse cx="12" cy="5" rx="9" ry="3"/>
                <path d="M3 5v14a9 3 0 0 0 18 0V5"/>
                <path d="M3 12a9 3 0 0 0 18 0"/>
            </svg>
            <span class="nav-link-text">Backups</span>
        </span>
    </MudNavLink>
    <MudNavLink Href="settings" Ripple="false">
        <span class="nav-link-inner">
            <span class="nav-mascot-cycle" aria-hidden="true">
                <img src="assets/anime/nav/nav-settings-a.webp" alt="" />
                <img src="assets/anime/nav/nav-settings-b.webp" alt="" />
                <img src="assets/anime/nav/nav-settings-c.webp" alt="" />
            </span>
            <svg class="nav-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06-.06a2 2 0 1 1-2.83-2.83l.06.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
            <span class="nav-link-text">Settings</span>
        </span>
    </MudNavLink>
</MudNavMenu>
</div>

@code {
    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("initNavIndicator");
            }
            catch
            {
                // Fallback
            }
        }
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("repositionNavIndicator");
        }
        catch
        {
            // Fallback
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
