@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="true" />
<MudPopoverProvider />

@Body

<style>
    /* The palette page renders inside a transparent extension iframe overlaying
       the current tab, so the app shell background must not paint. */
    html, body, #app {
        background: transparent !important;
    }
    /* Must stay "light" to match the extension's palette-host frame chain;
       a color-scheme mismatch makes Chromium paint this cross-origin iframe
       on an opaque canvas (MudBlazor's dark theme would set it to dark). */
    html {
        color-scheme: light !important;
    }
</style>
