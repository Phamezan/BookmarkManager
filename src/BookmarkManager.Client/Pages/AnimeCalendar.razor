@page "/anime-calendar"
@using BookmarkManager.Client.Features.AnimeCalendar
@using BookmarkManager.Client.Features.MangaCalendar.Components
@implements IDisposable

<PageTitle>Anime Calendar</PageTitle>

<div class="bookmarks-workspace anime-cal-workspace">
    @* Decorative night-watch backdrop (Shenron's Watch skin). Renders visibly only
       under [data-theme="anime"] — hidden by default in anime-calendar.css. *@
    <div class="anime-art" aria-hidden="true">
        <div class="anime-art-sky"></div>
        <img class="anime-art-bg" src="assets/anime/calendar/background.webp" alt="" />
        <div class="anime-art-stars anime-art-stars-a"></div>
        <div class="anime-art-stars anime-art-stars-b"></div>
        <img class="anime-art-shenron" src="assets/anime/calendar/shenron.webp" alt="" />
    </div>
    <main class="bookmark-zone anime-cal-zone flex-grow-1" style="grid-column: 1 / -1;">
        <div class="acal-media-tabs" role="tablist">
            <button type="button" role="tab" class="@($"acal-media-tab{(_mediaTab == MediaTab.Anime ? " is-active" : "")}")"
                    aria-selected="@(_mediaTab == MediaTab.Anime)" @onclick="() => _mediaTab = MediaTab.Anime">
                Anime
            </button>
            <button type="button" role="tab" class="@($"acal-media-tab{(_mediaTab == MediaTab.Manhwa ? " is-active" : "")}")"
                    aria-selected="@(_mediaTab == MediaTab.Manhwa)" @onclick="() => _mediaTab = MediaTab.Manhwa">
                Manga
            </button>
        </div>

        @if (_mediaTab == MediaTab.Manhwa)
        {
            <MangaCalendarPanel />
        }
        else
        {
        @if (_flatFolders.Count > 0)
        {
            <div class="rec-controls-row">
                <div class="rec-folder-chips">
                    @foreach (var folder in _flatFolders)
                    {
                        var isSelected = _selectedFolderIds.Contains(folder.Id);
                        <button type="button" class="@($"rec-folder-chip{(isSelected ? " is-checked" : "")}")"
                                @onclick="@(() => ToggleFolderAsync(folder.Id, !isSelected))">
                            @folder.Title
                        </button>
                    }
                </div>

                <div class="rec-chip-actions">
                    @if (_unmatchedBookmarks.Count > 0)
                    {
                        <button type="button" class="rec-clear-btn acal-match-btn" disabled="@_autoMatching" @onclick="() => AutoMatchAllAsync(false)">
                            <img class="acal-match-ball" src="assets/anime/calendar/db-4.webp" alt="" aria-hidden="true" />
                            @if (_autoMatching)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                            }
                            Match @_unmatchedBookmarks.Count new
                        </button>
                    }
                    <button type="button" class="rec-clear-btn" disabled="@(_selectedFolderIds.Count == 0)" @onclick="ClearFoldersAsync">
                        Clear all
                    </button>
                </div>
            </div>
        }

        @if (_aniListDegraded)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                AniList's API is running in a degraded, rate-limited mode right now - new matches and schedule updates may take longer to appear.
            </MudAlert>
        }

        @if (_selectedFolderIds.Count > 0 && !_loading)
        {
            <p class="rec-subtitle" style="margin-bottom: var(--bm-space-4);">
                @_airingCount airing anime found &middot; @_finishedCount with no upcoming episodes.
            </p>
        }

        <div class="rec-divider"></div>

        @if (_flatFolders.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon-wrap" aria-hidden="true">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" />
                </div>
                <div class="empty-state-copy">
                    <MudText Typo="Typo.h6" Class="empty-state-title">No anime-tagged bookmarks found</MudText>
                    <MudText Typo="Typo.body2" Class="empty-state-sub">Run the auto-tagger to tag your bookmarks - folders containing bookmarks tagged "Anime" will show up here.</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2"
                               StartIcon="@Icons.Material.Filled.AutoAwesome" OnClick="GoToAutoTagging">
                        Go to autotagging
                    </MudButton>
                </div>
            </div>
        }
        else if (_selectedFolderIds.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon-wrap" aria-hidden="true">
                    <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" />
                </div>
                <div class="empty-state-copy">
                    <MudText Typo="Typo.h6" Class="empty-state-title">Choose folders to build your calendar</MudText>
                    <MudText Typo="Typo.body2" Class="empty-state-sub">Select one or more folders above. Only bookmarks tagged "Anime" are scanned.</MudText>
                </div>
            </div>
        }
        else
        {
            <div class="anime-cal">
                <div class="acal-toolbar-wrap">
                    <CalendarToolbar Current="_view" CurrentChanged="SetView"
                                     Eyebrow="@ToolbarEyebrow" Title="@ToolbarTitle"
                                     OnPrev="GoPrev" OnNext="GoNext" />
                    @* Decorative gathering strip: one ball per dragon ball, lit while at
                       least that many airing series are gathered this period. *@
                    <div class="acal-gather" aria-hidden="true" title="Dragon balls gathered this week">
                        @for (var i = 1; i <= 7; i++)
                        {
                            var ball = i;
                            <img class="@(ball > Math.Min(7, _airingCount) ? "is-dim" : null)"
                                 src="@($"assets/anime/calendar/db-{ball}.webp")" alt="" loading="lazy" />
                        }
                    </div>
                </div>

                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" Class="mb-2" />
                }

                @switch (_view)
                {
                    case AnimeCalendarView.Month:
                        <MonthView Items="_items" Anchor="_anchor" OnItemClick="OnItemClicked" OnDaySelected="OnMonthDaySelected" />
                        break;
                    case AnimeCalendarView.Day:
                        <DayView Items="_items" Anchor="_anchor" OnItemClick="OnItemClicked" />
                        break;
                    default:
                        <WeekView Items="_items" Anchor="_anchor" OnItemClick="OnItemClicked" />
                        break;
                }
            </div>
        }
        }
    </main>
</div>
