@page "/bookmarks"
@page "/"
@using BookmarkManager.Contracts
@using BookmarkManager.Client.Components
@using BookmarkManager.Client.Features.Bookmarks.Components

<PageTitle>Bookmarks</PageTitle>

@if (!ExtensionConnectionService.IsConnected)
{
    <ExtensionOfflineNotice />
}
else
{
    <div class="bookmarks-workspace">
        <BookmarkSidebar TreeLoading="@_treeLoading"
                         FolderTree="@_folderTree"
                         SelectedFolderId="@_selectedFolderId"
                         @bind-ExpandedItems="@_expandedFolderIds"
                         CreateFolder="@CreateFolder"
                         ExpandAllFolders="@ExpandAllFolders"
                         CollapseAllFolders="@CollapseAllFolders"
                         FolderSelected="@OnFolderSelected"
                         FolderDrop="@OnFolderDrop"
                         FolderDragStart="@OnFolderDragStart"
                         FolderContextMenu="@OnFolderContextMenu"
                         FolderCreated="@OnFolderCreated" />

        <main class="bookmark-zone">
            <div class="bookmark-header">
                <BookmarksToolbar SelectedCount="@_selectedBookmarkIds.Count"
                                  IsAllSelected="IsAllSelected()"
                                  SearchQuery="@_searchQuery"
                                  SearchChanged="OnSearchChanged"
                                  ToggleSelectAll="ToggleSelectAllButton"
                                  ClearSelection="@ClearSelectionAndAnchor"
                                  MoveSelected="MoveSelected"
                                  DeleteSelected="DeleteSelected"
                                  CreateBookmark="CreateBookmark"
                                  OpenAutoTaggerDialog="OpenAutoTaggerDialog"
                                  SortMode="@_sortMode"
                                  SortModeChanged="OnSortModeChanged"
                                  TypeFilter="@_typeFilter"
                                  TypeFilterChanged="OnTypeFilterChanged" />

                @if (ShouldShowTagBar)
                {
                    <div class="tag-filter-workspace">
                        <div class="active-filters-row">
                            <div class="active-filters-left">
                                <span class="filter-label">FILTERS</span>
                                <div class="active-chips-container">
                                    @foreach (var tag in _activeTagFilters)
                                    {
                                        <button class="active-chip" @onclick="@(() => ToggleTagFilter(tag))" type="button">
                                            @tag
                                            <span class="active-chip-close">×</span>
                                        </button>
                                    }
                                    @foreach (var host in _activeHostFilters)
                                    {
                                        <button class="active-chip" @onclick="@(() => ToggleHostFilter(host))" type="button">
                                            @host
                                            <span class="active-chip-close">×</span>
                                        </button>
                                    }
                                    @if (_activeTagFilters.Count == 0 && _activeHostFilters.Count == 0)
                                    {
                                        <span class="no-filters-placeholder">Select tags below to filter</span>
                                    }
                                </div>
                            </div>
                            <div class="tag-bar-actions">
                                @if (_activeTagFilters.Count > 0 || _activeHostFilters.Count > 0)
                                {
                                    <button class="clear-all-filters-btn" @onclick="ClearAllFilters" type="button">
                                        Clear All
                                    </button>
                                }
                                <button class="collapse-toggle-btn" @onclick="ToggleCollapse" type="button">
                                    @(_tagsCollapsed ? "Expand ▼" : "Collapse ▲")
                                </button>
                            </div>
                        </div>

                        @if (!_tagsCollapsed)
                        {
                            @if (_availableTags.Count > 0 || _availableHosts.Count > 0)
                            {
                                <div class="tag-categories-grid">
                                    @foreach (var group in GroupTags(_availableTags, _availableHosts))
                                    {
                                        <div class="category-row">
                                            <span class="category-label">@group.CategoryName</span>
                                            <div class="category-tags-container">
                                                @{
                                                    var isExpanded = _expandedCategories.Contains(group.CategoryName);
                                                    var visibleTags = isExpanded ? group.Tags : group.Tags.Take(6).ToList();
                                                    var hiddenCount = group.Tags.Count - visibleTags.Count;
                                                }
                                                @foreach (var tag in visibleTags)
                                                {
                                                    var active = group.IsHostGroup
                                                        ? _activeHostFilters.Contains(tag.Tag, StringComparer.OrdinalIgnoreCase)
                                                        : _activeTagFilters.Contains(tag.Tag, StringComparer.OrdinalIgnoreCase);
                                                    <button class="category-tag-btn @(active ? "active" : "")"
                                                            @onclick="@(() => { if (group.IsHostGroup) ToggleHostFilter(tag.Tag); else ToggleTagFilter(tag.Tag); })" type="button">
                                                        @tag.Tag <span class="tag-btn-count">@tag.Count</span>
                                                    </button>
                                                }
                                                @if (hiddenCount > 0)
                                                {
                                                    <button class="expand-more-link" @onclick="@(() => ToggleCategoryExpand(group.CategoryName))" type="button">
                                                        +@hiddenCount more
                                                    </button>
                                                }
                                                else if (isExpanded && group.Tags.Count > 6)
                                                {
                                                    <button class="expand-more-link" @onclick="@(() => ToggleCategoryExpand(group.CategoryName))" type="button">
                                                        show less
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else if (!_loading)
                            {
                                <div style="padding: 12px 8px; color: var(--bm-text-secondary); font-size: 0.875rem;">
                                    No tags found. Run auto tagger to automatically scan and tag your bookmarks.
                                </div>
                            }
                        }

                        <div class="tag-footer-row">
                            <div style="display: flex; align-items: center;">
                                @{
                                    var breadcrumbs = GetBreadcrumbs();
                                    if (breadcrumbs.Count > 0)
                                    {
                                        <div class="breadcrumbs-container" style="padding: 0; background: transparent !important; border: none !important; backdrop-filter: none !important; -webkit-backdrop-filter: none !important; box-shadow: none !important; font-size: 0.82rem; color: var(--bm-text-secondary); gap: var(--bm-space-2); margin-bottom: 0;">
                                            <span class="breadcrumb-item link" @onclick="@(() => OnFolderSelected(breadcrumbs[0].Id))" title="Go to Root" style="font-size: 0.82rem;">
                                                <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Small" Style="margin-right: 4px; color: var(--bm-text-secondary); width: 16px; height: 16px;" />
                                                Home
                                            </span>
                                            @for (int i = 0; i < breadcrumbs.Count; i++)
                                            {
                                                var crumb = breadcrumbs[i];
                                                var isLast = i == breadcrumbs.Count - 1;

                                                <span class="breadcrumb-separator" style="font-size: 0.82rem;">/</span>

                                                if (isLast)
                                                {
                                                    <span class="breadcrumb-item active" style="font-size: 0.82rem; font-weight: 600; color: var(--bm-text-primary);">@crumb.Title</span>
                                                }
                                                else
                                                {
                                                    <span class="breadcrumb-item link" @onclick="@(() => OnFolderSelected(crumb.Id))" style="font-size: 0.82rem;">
                                                        @crumb.Title
                                                    </span>
                                                }
                                            }
                                        </div>
                                    }
                                }
                            </div>

                            <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.AutoAwesome" OnClick="OpenAutoTaggerDialog"
                                       Disabled="@_loading">
                                Auto Tag
                            </MudButton>
                        </div>
                    </div>
                }
            </div>

            <BookmarkList Loading="@_loading"
                          Items="@VisibleItems"
                          SearchQuery="@_searchQuery"
                          CreateBookmark="CreateBookmark"
                          IsSelected="IsSelected"
                          FocusedId="@FocusedId"
                          GetFaviconUrl="GetFaviconUrl"
                          GetParentFolderName="GetParentFolderName"
                          GetFolderPath="GetFolderPath"
                          FormatUpdatedAt="FormatUpdatedAt"
                          RowClicked="OnRowClick"
                          CheckboxClicked="OnCheckboxClick"
                          ContextMenuOpened="OnBookmarkContextMenu"
                          BackgroundContextMenuOpened="OnListBackgroundContextMenu"
                          DragStarted="OnDragStart"
                          MarqueeSelectCompleted="OnMarqueeSelectCompleted"
                          MarqueeBackgroundClick="OnMarqueeBackgroundClick"
                          ColumnsChanged="OnGridColumnsChanged"
                          ToggleFavoriteAsync="ToggleFavorite"
                          EditBookmarkAsync="EditBookmark"
                          MoveBookmarkAsync="MoveBookmark"
                          DeleteBookmarkAsync="DeleteBookmark"
                          MoveFolderAsync="MoveFolder"
                          DeleteFolderAsync="DeleteFolder" />
        </main>
    </div>
}

@if (_contextMenuOpen)
{
    <div style="position: fixed; inset: 0; z-index: 9999; background: transparent;" @onclick="CloseContextMenu"
         @oncontextmenu="CloseContextMenu" @oncontextmenu:prevent="true" />
    <div class="custom-context-menu" style="@($"left: {(int)_contextMenuX}px; top: {(int)_contextMenuY}px;")">
        @if (_contextMenuType == "bookmark" && _contextMenuBookmark is not null)
        {
            <div class="custom-context-menu-header">@_contextMenuBookmark.Title</div>
            @if (!string.IsNullOrEmpty(_contextMenuBookmark.Url))
            {
                <button class="custom-context-menu-item" @onclick="OpenContextBookmarkInNewTab">
                    <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" />
                    <span>Open in New Tab</span>
                </button>
                <button class="custom-context-menu-item" @onclick="CopyContextBookmarkUrl">
                    <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" />
                    <span>Copy URL</span>
                </button>
            }
            @if (_contextMenuBookmark.ParentId is Guid bookmarkParentId)
            {
                <button class="custom-context-menu-item" @onclick="GoToContextBookmarkFolder">
                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" />
                    <span>Go to @GetParentFolderName(bookmarkParentId)</span>
                </button>
            }
            <button class="custom-context-menu-item" @onclick="ToggleFavoriteContextBookmark">
                <MudIcon Icon="@(_contextMenuBookmark.Metadata?.IsFavorite == true ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)"
                         Size="Size.Small" Style="@(_contextMenuBookmark.Metadata?.IsFavorite == true ? "color: #fbbf24;" : "")" />
                <span>@(_contextMenuBookmark.Metadata?.IsFavorite == true ? "Remove Favorite" : "Pin to Favorites")</span>
            </button>
            <button class="custom-context-menu-item" @onclick="EditContextBookmark">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                <span>Edit Bookmark</span>
            </button>
            @if (_contextSiblingFolders.Count > 0)
            {
                <div class="custom-context-menu-divider" />
                <div class="custom-context-menu-subheader">Move to folder</div>
                <div class="custom-context-menu-quick-actions">
                    @foreach (var folder in _contextSiblingFolders)
                    {
                        <button class="custom-context-menu-item" @onclick="@(() => MoveContextBookmarkToFolder(folder.Id))">
                            <MudIcon Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small" />
                            <span>@folder.Title</span>
                        </button>
                    }
                </div>
            }
            <button class="custom-context-menu-item" @onclick="MoveContextBookmark">
                <MudIcon Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small" />
                <span>Move to…</span>
            </button>
            <button class="custom-context-menu-item" @onclick="ArchiveContextBookmark">
                <MudIcon Icon="@Icons.Material.Filled.Archive" Size="Size.Small" />
                <span>Archive</span>
            </button>
            <div class="custom-context-menu-divider" />
            <button class="custom-context-menu-item danger" @onclick="DeleteContextBookmark">
                <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                <span>Delete Bookmark</span>
            </button>
        }
        else if (_contextMenuType == "folder" && _contextMenuFolderId != Guid.Empty)
        {
            var folder = FindFolderById(_folderTree, _contextMenuFolderId);
            var isFolderFavorite = _favorites.Any(f => f.Id == _contextMenuFolderId);
            <div class="custom-context-menu-header">@(folder?.Title ?? "Folder Options")</div>
            <button class="custom-context-menu-item" @onclick="OpenContextFolder">
                <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" />
                <span>Open Folder</span>
            </button>
            <button class="custom-context-menu-item" @onclick="ToggleFavoriteContextFolder">
                <MudIcon Icon="@(isFolderFavorite ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)"
                         Size="Size.Small" Style="@(isFolderFavorite ? "color: #fbbf24;" : "")" />
                <span>@(isFolderFavorite ? "Remove Favorite" : "Pin to Favorites")</span>
            </button>
            <button class="custom-context-menu-item" @onclick="CreateBookmarkInContextFolder">
                <MudIcon Icon="@Icons.Material.Filled.AddLink" Size="Size.Small" />
                <span>New Bookmark</span>
            </button>
            @if (_contextSiblingFolders.Count > 0)
            {
                <div class="custom-context-menu-divider" />
                <div class="custom-context-menu-subheader">Move to folder</div>
                <div class="custom-context-menu-quick-actions">
                    @foreach (var sibling in _contextSiblingFolders)
                    {
                        <button class="custom-context-menu-item" @onclick="@(() => MoveContextFolderToSibling(sibling.Id))">
                            <MudIcon Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small" />
                            <span>@sibling.Title</span>
                        </button>
                    }
                </div>
            }
            <button class="custom-context-menu-item" @onclick="MoveContextFolder">
                <MudIcon Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small" />
                <span>Move to…</span>
            </button>
            <div class="custom-context-menu-divider" />
            <button class="custom-context-menu-item danger" @onclick="DeleteContextFolder">
                <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                <span>Delete Folder</span>
            </button>
        }
        else if (_contextMenuType == "empty")
        {
            <div class="custom-context-menu-header">Bookmarks</div>
            <button class="custom-context-menu-item" @onclick="CreateBookmarkAtEmptyContext">
                <MudIcon Icon="@Icons.Material.Filled.AddLink" Size="Size.Small" />
                <span>New Bookmark Here</span>
            </button>
            <button class="custom-context-menu-item" @onclick="CreateFolderAtEmptyContext">
                <MudIcon Icon="@Icons.Material.Filled.CreateNewFolder" Size="Size.Small" />
                <span>New Folder Here</span>
            </button>
            <div class="custom-context-menu-divider" />
            <button class="custom-context-menu-item" @onclick="PasteUrlAtEmptyContext">
                <MudIcon Icon="@Icons.Material.Filled.ContentPaste" Size="Size.Small" />
                <span>Paste URL</span>
            </button>
        }
    </div>
}

<style>
    .highlight-flash {
        animation: highlight-flash-anim 3s ease-out !important;
    }
    @@keyframes highlight-flash-anim {
        0% {
            background-color: rgba(208, 188, 255, 0.4) !important;
            box-shadow: 0 0 15px rgba(208, 188, 255, 0.6) !important;
        }
        100% {
            background-color: transparent;
            box-shadow: none;
        }
    }
</style>
