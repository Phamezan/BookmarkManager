@page "/bookmarks"
@page "/"
@implements IDisposable
@using BookmarkManager.Contracts
@using BookmarkManager.Client.Components

<PageTitle>Bookmarks</PageTitle>

<div class="bookmarks-workspace">
    <MudPaper Elevation="0" Class="folder-zone">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="zone-heading">
            <div>
                <MudText Typo="Typo.subtitle1">Tracked Roots</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Protected Brave folders stay scoped.</MudText>
            </div>
            <MudTooltip Text="Create folder">
                <MudIconButton Icon="@Icons.Material.Filled.CreateNewFolder" Size="Size.Small" OnClick="@CreateFolder" aria-label="Create folder" />
            </MudTooltip>
        </MudStack>

        <div class="overflow-auto flex-grow-1 pa-2">
            @if (_treeLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_folderTree.Count == 0)
            {
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" />
                    <MudText>No folders yet</MudText>
                </div>
            }
            else
            {
                <FolderTree Folders="_folderTree"
                             SelectedFolderId="_selectedFolderId"
                             FolderSelected="@OnFolderSelected"
                             FolderDrop="@OnFolderDrop"
                             FolderDragStart="@OnFolderDragStart"
                             FolderContextMenu="@OnFolderContextMenu"
                             @bind-ExpandedItems="_expandedFolderIds" />
            }
        </div>
    </MudPaper>

    <main class="bookmark-zone">
        <div class="bookmark-header">
             <!-- Favorites / Shortcuts Section (Horizontal List) -->
             <section class="tracked-roots-section">
                 <div class="tracked-roots-list" 
                      data-drop-target="true"
                      @ondragover:prevent
                      @ondragover="OnFavoritesDragOver"
                      @ondragleave="OnFavoritesDragLeave"
                      @ondrop="OnFavoritesDrop"
                      style="@($"margin-top: 8px; min-height: 72px; align-items: center; border-radius: 8px; transition: all 0.2s ease; {_favoritesDragOverStyle}")">
                     @if (_favorites.Count == 0)
                     {
                         <div class="favorites-empty-placeholder" style="color: var(--bm-text-secondary); font-size: 0.85rem; padding: 16px; display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; border: 2px dashed rgba(148, 163, 184, 0.2); border-radius: 8px; min-height: 60px;">
                             <MudIcon Icon="@Icons.Material.Filled.StarBorder" Size="Size.Small" Style="color: #fbbf24;" />
                             <span>No shortcuts pinned to favorites yet. Drag folders here from the tree, or drag cards here to pin them.</span>
                         </div>
                     }
                     else
                     {
                         @foreach (var fav in _favorites)
                         {
                             @if (fav.Type == NodeType.Folder)
                             {
                                 <div class="root-card @(fav.Id == _selectedFolderId ? "active" : "")" @onclick="@(() => OnFolderSelected(fav.Id))" style="padding-right: 8px;">
                                     <div class="root-card-icon">
                                         <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Medium" Style="@($"color: {FolderColorHelper.GetFolderColor(fav.Title)};")" />
                                     </div>
                                     <div class="root-card-info">
                                         <div class="root-card-title" title="@fav.Title">@fav.Title</div>
                                         <div class="root-card-path">Folder Shortcut</div>
                                     </div>
                                     <div class="root-card-count" @onclick:stopPropagation @onclick="@(() => ToggleFavorite(fav))" style="cursor: pointer;" title="Remove from Shortcuts">
                                         <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                     </div>
                                 </div>
                             }
                             else
                             {
                                 <a href="@fav.Url" target="_blank" rel="noopener noreferrer" class="root-card" style="text-decoration: none; padding-right: 8px;" @onclick:stopPropagation>
                                     <div class="root-card-icon">
                                         @if (!string.IsNullOrEmpty(fav.Url))
                                         {
                                             var faviconUrl = GetFaviconUrl(fav.Url);
                                             @if (faviconUrl != null)
                                             {
                                                 <img src="@faviconUrl" alt="" width="20" height="20" onerror="this.style.display='none'" />
                                             }
                                             else
                                             {
                                                 <MudIcon Icon="@Icons.Material.Filled.Bookmark" Size="Size.Medium" Style="color: var(--bm-accent);" />
                                             }
                                         }
                                         else
                                         {
                                             <MudIcon Icon="@Icons.Material.Filled.Bookmark" Size="Size.Medium" Style="color: var(--bm-accent);" />
                                         }
                                     </div>
                                     <div class="root-card-info">
                                         <div class="root-card-title" title="@fav.Title">@fav.Title</div>
                                         <div class="root-card-path">Link Shortcut</div>
                                     </div>
                                     <div class="root-card-count" @onclick:stopPropagation @onclick="@(() => ToggleFavorite(fav))" style="cursor: pointer;" title="Remove from Shortcuts">
                                         <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                     </div>
                                 </a>
                             }
                         }
                     }
                 </div>
             </section>

             <!-- Toolbar & Selection Row -->
             <div class="header-select-row" style="display: block;">
                 <div class="header-content-container">
                     @if (_selectedBookmarkIds.Count > 0)
                     {
                         <div class="selection-bar">
                             <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                 <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                     <div class="bookmark-select mr-2" style="display: flex; align-items: center; padding-left: 4px;">
                                         <input type="checkbox"
                                                checked="@IsAllSelected()"
                                                @onchange="ToggleSelectAll"
                                                class="bm-checkbox master-checkbox"
                                                aria-label="Select all" />
                                     </div>
                                     <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _selectedBookmarkIds.Clear())" aria-label="Clear selection" />
                                     <MudText Typo="Typo.subtitle2" Class="ml-2">@_selectedBookmarkIds.Count selected</MudText>
                                 </MudStack>
                                 <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                     <MudButton Variant="Variant.Filled" 
                                                Color="Color.Primary" 
                                                StartIcon="@Icons.Material.Filled.DriveFileMove" 
                                                Size="Size.Small" 
                                                OnClick="@MoveSelected">
                                         Move
                                     </MudButton>
                                     <MudButton Variant="Variant.Filled" 
                                                Color="Color.Error" 
                                                StartIcon="@Icons.Material.Filled.Delete" 
                                                Size="Size.Small" 
                                                OnClick="@DeleteSelected">
                                         Delete
                                     </MudButton>
                                 </MudStack>
                             </MudStack>
                         </div>
                     }
                     else
                     {
                         <MudPaper Elevation="0" Class="explorer-toolbar">
                             <div class="bookmark-select mr-2" style="display: flex; align-items: center; height: 100%; padding-left: 4px;">
                                 <input type="checkbox"
                                        checked="@IsAllSelected()"
                                        @onchange="ToggleSelectAll"
                                        class="bm-checkbox master-checkbox"
                                        aria-label="Select all" />
                             </div>
                             <MudTextField Value="_searchQuery"
                                           ValueChanged="@((string? v) => OnSearchChanged(v))"
                                           Placeholder="Search title or URL"
                                           Variant="Variant.Outlined"
                                           Immediate="true"
                                           DebounceInterval="400"
                                           Margin="Margin.Dense"
                                           Class="toolbar-search"
                                           Adornment="Adornment.End"
                                           AdornmentIcon="@Icons.Material.Filled.Search" />
                             <MudSelect @bind-Value="_typeFilter" Label="Filter" Margin="Margin.Dense" Dense="true" Class="toolbar-select filter-select">
                                 <MudSelectItem Value="@("All")">All Types</MudSelectItem>
                                 <MudSelectItem Value="@("Folders")">Folders Only</MudSelectItem>
                                 <MudSelectItem Value="@("Bookmarks")">Bookmarks Only</MudSelectItem>
                                 <MudSelectItem Value="@("Favorites")">Favorites Only</MudSelectItem>
                             </MudSelect>
                             <MudSelect @bind-Value="_sortMode" Label="Sort" Margin="Margin.Dense" Dense="true" Class="toolbar-select sort-select">
                                 <MudSelectItem Value="@("TitleAsc")">Title A-Z</MudSelectItem>
                                 <MudSelectItem Value="@("TitleDesc")">Title Z-A</MudSelectItem>
                                 <MudSelectItem Value="@("UpdatedDesc")">Newest First</MudSelectItem>
                                 <MudSelectItem Value="@("UpdatedAsc")">Oldest First</MudSelectItem>
                             </MudSelect>
                             <MudTooltip Text="Create bookmark">
                                 <MudIconButton Icon="@Icons.Material.Filled.AddLink" Color="Color.Primary" OnClick="@CreateBookmark" aria-label="Create bookmark" />
                             </MudTooltip>
                         </MudPaper>
                     }
                 </div>
             </div>
        </div>

        <div class="bookmark-list">
            @if (_loading)
            {
                <div class="bookmark-grid" aria-label="Loading bookmarks...">
                    @for (int i = 0; i < 6; i++)
                    {
                        <div class="skeleton-card" />
                    }
                </div>
            }
            else if (_items.Count == 0)
            {
                <div class="empty-state">
                    <MudIcon Icon="@(string.IsNullOrWhiteSpace(_searchQuery) ? Icons.Material.Filled.BookmarkBorder : Icons.Material.Filled.SearchOff)" />
                    <MudText>
                        @(string.IsNullOrWhiteSpace(_searchQuery)
                            ? "Select a folder to view bookmarks"
                            : "No bookmarks match your search")
                    </MudText>
                </div>
            }
            else
            {
                <div class="bookmark-grid" role="list" aria-label="Bookmarks">
                    @* Render Folders First *@
                    @foreach (var item in PaginatedItems.Where(i => i.Type == NodeType.Folder))
                    {
                        <div @oncontextmenu="@((e) => OnBookmarkContextMenu(e, item))"
                             @oncontextmenu:preventDefault="true"
                             @oncontextmenu:stopPropagation="true"
                             style="display: contents;">
                            <div class="@($"bookmark-card {(IsSelected(item.Id) ? "is-selected" : "")}")"
                                 role="listitem"
                                 draggable="true"
                                 data-drag-type="bookmark"
                                 data-drag-id="@item.Id"
                                 @ondragstart="@(() => OnDragStart(item.Id))"
                                 @onclick="@((e) => OnRowClick(e, item))">
                                <div class="bookmark-select" @onclick:stopPropagation>
                                    <input type="checkbox"
                                           checked="@IsSelected(item.Id)"
                                           @onclick="@((e) => OnCheckboxClick(e, item.Id))"
                                           class="bm-checkbox"
                                           aria-label="@($"Select {item.Title}")" />
                                </div>
                                
                                <div class="bookmark-card-header">
                                    <div class="bookmark-card-title-group">
                                        <div class="bookmark-card-icon">
                                            <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Style="@($"color: {FolderColorHelper.GetFolderColor(item.Title)};")" />
                                        </div>
                                        <h3 class="bookmark-card-title" title="@item.Title">
                                            <span>@item.Title</span>
                                            @if (item.Metadata?.IsFavorite == true)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Style="color: #fbbf24; margin-left: 6px; vertical-align: middle;" />
                                            }
                                        </h3>
                                    </div>
                                </div>

                                <div class="bookmark-card-footer">
                                    <div class="bookmark-card-tags">
                                        @if (item.Metadata?.Category != null)
                                        {
                                            <span class="tag-badge">@item.Metadata.Category</span>
                                        }
                                        @if (item.Metadata?.Tags != null)
                                        {
                                            @foreach (var tag in item.Metadata.Tags.Take(2))
                                            {
                                                <span class="tag-badge">@tag</span>
                                            }
                                        }
                                    </div>
                                    <span class="bookmark-card-time">@item.UpdatedAt.ToLocalTime().ToString("g")</span>
                                </div>

                                <div class="bookmark-card-actions" @onclick:stopPropagation>
                                    <MudTooltip Text="@(item.Metadata?.IsFavorite == true ? "Remove from Favorites" : "Add to Favorites")">
                                        <MudIconButton Icon="@(item.Metadata?.IsFavorite == true ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)" Size="Size.Small" Style="@(item.Metadata?.IsFavorite == true ? "color: #fbbf24;" : "")" OnClick="@(() => ToggleFavorite(item))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Move folder">
                                        <MudIconButton Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small" OnClick="@(() => MoveFolder(item.Id))" aria-label="@($"Move {item.Title}")" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete folder">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteFolder(item.Id))" aria-label="@($"Delete {item.Title}")" />
                                    </MudTooltip>
                                </div>
                            </div>
                        </div>
                    }

                    @* Render Bookmarks Second *@
                    @foreach (var item in PaginatedItems.Where(i => i.Type != NodeType.Folder))
                    {
                        <div @oncontextmenu="@((e) => OnBookmarkContextMenu(e, item))"
                             @oncontextmenu:preventDefault="true"
                             @oncontextmenu:stopPropagation="true"
                             style="display: contents;">
                            <div class="@($"bookmark-card {(IsSelected(item.Id) ? "is-selected" : "")}")"
                                 role="listitem"
                                 draggable="true"
                                 data-drag-type="bookmark"
                                 data-drag-id="@item.Id"
                                 @ondragstart="@(() => OnDragStart(item.Id))"
                                 @onclick="@((e) => OnRowClick(e, item))">
                                <div class="bookmark-select" @onclick:stopPropagation>
                                    <input type="checkbox"
                                           checked="@IsSelected(item.Id)"
                                           @onclick="@((e) => OnCheckboxClick(e, item.Id))"
                                           class="bm-checkbox"
                                           aria-label="@($"Select {item.Title}")" />
                                </div>
                                
                                <div class="bookmark-card-header">
                                    <div class="bookmark-card-title-group">
                                        <div class="bookmark-card-icon">
                                            @if (!string.IsNullOrEmpty(item.Url))
                                            {
                                                var faviconUrl = GetFaviconUrl(item.Url);
                                                @if (faviconUrl != null)
                                                {
                                                    <img src="@faviconUrl"
                                                         alt=""
                                                         width="16" height="16"
                                                         onerror="this.style.display='none'" />
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.Bookmark" Size="Size.Small" />
                                                }
                                            }
                                        </div>
                                        <h3 class="bookmark-card-title" title="@item.Title">
                                            @if (!string.IsNullOrEmpty(item.Url))
                                            {
                                                <a href="@item.Url" target="_blank" rel="noopener noreferrer" @onclick:stopPropagation>@item.Title</a>
                                            }
                                            else
                                            {
                                                <span>@item.Title</span>
                                            }
                                            @if (item.Metadata?.IsFavorite == true)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Style="color: #fbbf24; margin-left: 6px; vertical-align: middle;" />
                                            }
                                        </h3>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(item.Url))
                                {
                                    <a href="@item.Url" target="_blank" class="bookmark-card-url" title="@item.Url" @onclick:stopPropagation>@item.Url</a>
                                }

                                <div class="bookmark-card-footer">
                                    <div class="bookmark-card-tags">
                                        @if (item.Metadata?.Category != null)
                                        {
                                            <span class="tag-badge">@item.Metadata.Category</span>
                                        }
                                        @if (item.Metadata?.Tags != null)
                                        {
                                            @foreach (var tag in item.Metadata.Tags.Take(2))
                                            {
                                                <span class="tag-badge">@tag</span>
                                            }
                                        }
                                    </div>
                                    <span class="bookmark-card-time">@item.UpdatedAt.ToLocalTime().ToString("g")</span>
                                </div>

                                <div class="bookmark-card-actions" @onclick:stopPropagation>
                                    <MudTooltip Text="@(item.Metadata?.IsFavorite == true ? "Remove from Favorites" : "Add to Favorites")">
                                        <MudIconButton Icon="@(item.Metadata?.IsFavorite == true ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)" Size="Size.Small" Style="@(item.Metadata?.IsFavorite == true ? "color: #fbbf24;" : "")" OnClick="@(() => ToggleFavorite(item))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Edit fields">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => EditBookmark(item))" aria-label="@($"Edit {item.Title}")" />
                                    </MudTooltip>
                                    <MudTooltip Text="Move bookmark">
                                        <MudIconButton Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small" OnClick="@(() => MoveBookmark(item))" aria-label="@($"Move {item.Title}")" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete bookmark">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteBookmark(item))" aria-label="@($"Delete {item.Title}")" />
                                    </MudTooltip>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                @if (PageCount > 1)
                {
                    <div class="d-flex justify-center mt-4 mb-4">
                        <MudPagination SelectedChanged="OnPageChanged" Count="PageCount" Selected="_currentPage" Color="Color.Primary" Variant="Variant.Filled" />
                    </div>
                }
            }
        </div>
    </main>
</div>

@if (_contextMenuOpen)
{
    <div style="position: fixed; inset: 0; z-index: 9999; background: transparent;" @onclick="CloseContextMenu" @oncontextmenu="CloseContextMenu" @oncontextmenu:prevent="true" />
    <div class="custom-context-menu" style="@($"left: {(int)_contextMenuX}px; top: {(int)_contextMenuY}px;")">
        @if (_contextMenuType == "bookmark" && _contextMenuBookmark is not null)
        {
            <div class="custom-context-menu-header">@_contextMenuBookmark.Title</div>
            <button class="custom-context-menu-item" @onclick="ToggleFavoriteContextBookmark">
                <MudIcon Icon="@(_contextMenuBookmark.Metadata?.IsFavorite == true ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)" Size="Size.Small" Style="@(_contextMenuBookmark.Metadata?.IsFavorite == true ? "color: #fbbf24;" : "")" />
                <span>@(_contextMenuBookmark.Metadata?.IsFavorite == true ? "Remove Favorite" : "Pin to Favorites")</span>
            </button>
            <button class="custom-context-menu-item" @onclick="EditContextBookmark">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                <span>Edit Bookmark</span>
            </button>
            <button class="custom-context-menu-item" @onclick="MoveContextBookmark">
                <MudIcon Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small" />
                <span>Move Bookmark</span>
            </button>
            <div class="custom-context-menu-divider" />
            <button class="custom-context-menu-item danger" @onclick="DeleteContextBookmark">
                <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                <span>Delete Bookmark</span>
            </button>
        }
        else if (_contextMenuType == "folder" && _contextMenuFolderId != Guid.Empty)
        {
            var folder = FindFolderById(_folderTree, _contextMenuFolderId);
            var isFolderFavorite = _favorites.Any(f => f.Id == _contextMenuFolderId);
            <div class="custom-context-menu-header">@(folder?.Title ?? "Folder Options")</div>
            <button class="custom-context-menu-item" @onclick="ToggleFavoriteContextFolder">
                <MudIcon Icon="@(isFolderFavorite ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)" Size="Size.Small" Style="@(isFolderFavorite ? "color: #fbbf24;" : "")" />
                <span>@(isFolderFavorite ? "Remove Favorite" : "Pin to Favorites")</span>
            </button>
            <button class="custom-context-menu-item" @onclick="CreateBookmarkInContextFolder">
                <MudIcon Icon="@Icons.Material.Filled.AddLink" Size="Size.Small" />
                <span>New Bookmark</span>
            </button>
            <button class="custom-context-menu-item" @onclick="MoveContextFolder">
                <MudIcon Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small" />
                <span>Move Folder</span>
            </button>
            <div class="custom-context-menu-divider" />
            <button class="custom-context-menu-item danger" @onclick="DeleteContextFolder">
                <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                <span>Delete Folder</span>
            </button>
        }
    </div>
}
