@page "/library"
@using BookmarkManager.Client.Features.Library
@using BookmarkManager.Client.Features.Library.Components
@using BookmarkManager.Client.Services
@using BookmarkManager.Contracts
@inject ISnackbar Snackbar
@inject ILibraryService LibraryService
@inject IDialogService DialogService
@inject IBookmarkService BookmarkService
@inject UndoService UndoService

<PageTitle>Library</PageTitle>

<div class="library-page">
    <header class="lib-header">
        <div class="lib-heading">
            <h1 class="lib-title">Library</h1>
            <span class="lib-subtitle">
                @(IsSearchActive || _updatesBehindOnly ? ActiveItems.Count : _trendingTotalCount) titles · @TrackedCount tracked
            </span>
        </div>
    </header>

    <div class="lib-controls">
        <div class="lib-tabs" role="tablist" aria-label="Media type">
            <button type="button" role="tab" aria-selected="@(!_updatesBehindOnly && _selectedType is null)"
                    class="@TabClass(null)" @onclick="@(() => SelectType(null))">All</button>
            @foreach (var type in MediaTypes)
            {
                var current = type;
                <button type="button" role="tab" aria-selected="@(!_updatesBehindOnly && _selectedType == current)"
                        class="@TabClass(current)" @onclick="@(() => SelectType(current))">
                    @TypeLabel(current)
                </button>
            }
            <button type="button" role="tab" aria-selected="@(_updatesBehindOnly)"
                    class="@UpdatesBehindClass()" @onclick="ToggleUpdatesBehind">Updates Behind</button>
        </div>
        <div class="lib-search">
            <svg class="lib-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input class="lib-search-input" type="search" placeholder="Search titles or authors…"
                   value="@_search" @oninput="OnSearchInput" aria-label="Search the library" />
            @if (!string.IsNullOrWhiteSpace(_search))
            {
                <button type="button" class="lib-search-clear" @onclick="ClearSearch"
                        aria-label="Clear search">✕</button>
            }
        </div>
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                 ListClass="lib-sort-list" Class="lib-sort-menu">
            <ActivatorContent>
                <button type="button" class="lib-sort-btn" aria-label="Sort order">
                    <svg class="lib-sort-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="4" y1="6" x2="15" y2="6"/>
                        <line x1="4" y1="12" x2="12" y2="12"/>
                        <line x1="4" y1="18" x2="9" y2="18"/>
                        <polyline points="17 10 20 13 23 10" transform="translate(-2 0)"/>
                        <line x1="18" y1="5" x2="18" y2="13"/>
                    </svg>
                    <span class="lib-sort-btn-label">@SortLabel(_sort)</span>
                    <svg class="lib-sort-btn-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>
            </ActivatorContent>
            <ChildContent>
                @foreach (var (key, label) in SortOptions)
                {
                    var current = key;
                    <MudMenuItem Class="@($"lib-sort-item{(_sort == current ? " is-active" : "")}")"
                                 OnClick="@(() => _sort = current)">
                        <span class="lib-sort-item-label">@label</span>
                        @if (_sort == current)
                        {
                            <span class="lib-sort-item-check" aria-hidden="true">✓</span>
                        }
                    </MudMenuItem>
                }
            </ChildContent>
        </MudMenu>
    </div>

    <div class="lib-genres" aria-label="Genre filters">
        @foreach (var genre in AllGenres)
        {
            var current = genre;
            var isChecked = _selectedGenres.Contains(current);
            <button type="button" class="@($"lib-genre-chip{(isChecked ? " is-checked" : "")}")"
                    aria-pressed="@isChecked" @onclick="@(() => ToggleGenre(current))">
                @current
            </button>
        }
        @if (HasActiveFilters)
        {
            <button type="button" class="lib-clear-btn" @onclick="ClearFilters">Clear all</button>
        }
    </div>

    @if (!HasActiveFilters && Featured is { } featured)
    {
        <section class="lib-hero" style="@LibraryCoverArt.StyleFor(featured)" aria-label="Trending this week">
            <div class="lib-hero-backdrop" aria-hidden="true"></div>
            <div class="lib-hero-content" @key="featured.Title">
                <div class="lib-hero-info">
                    <span class="lib-hero-eyebrow">
                        <span class="lib-hero-pulse" aria-hidden="true"></span>
                        Trending this week · #@(_featuredIndex + 1) of @TrendingItems.Count
                    </span>
                    <h2 class="lib-hero-title">@featured.Title</h2>
                    <div class="lib-hero-stats">
                        @if (featured.Rating is { } featuredRating)
                        {
                            <span class="lib-hero-stat lib-hero-rating">★ @featuredRating.ToString("0.0")</span>
                        }
                        <span class="lib-hero-stat">@featured.TypeLabel</span>
                        <span class="lib-hero-stat">Ch. @(featured.LatestChapter ?? "—")</span>
                        <span class="lib-hero-stat">@(featured.Status ?? "Unknown")</span>
                        <span class="lib-hero-stat lib-hero-provider">@featured.Provider</span>
                    </div>
                    <p class="lib-hero-synopsis">@(featured.Synopsis ?? "No synopsis available.")</p>
                    <div class="lib-hero-genres">
                        @foreach (var genre in featured.Genres)
                        {
                            var current = genre;
                            <button type="button" class="lib-hero-genre" title="Filter by @current"
                                    @onclick="@(() => ToggleGenre(current))">@current</button>
                        }
                    </div>
                    <div class="lib-hero-actions">
                        <button type="button"
                                class="@($"lib-hero-track{(featured.IsTracked ? " is-tracked" : "")}")"
                                @onclick="@(() => TrackItem(featured))">
                            @(featured.IsTracked ? "Tracked ✓" : "+ Track this title")
                        </button>
                        @if (featured.ChaptersBehind is > 0)
                        {
                            <span class="lib-hero-behind">@featured.ChaptersBehind chapters behind</span>
                        }
                        <span class="lib-hero-updated">Updated @featured.UpdatedLabel</span>
                    </div>
                </div>
                <div class="@($"lib-hero-cover {LibraryCoverArt.CoverClass(featured)}")" style="@LibraryCoverArt.StyleFor(featured)" aria-hidden="true">
                    <span class="lib-hero-cover-spine"></span>
                    <div class="lib-hero-cover-text">
                        <span class="lib-hero-cover-title">@featured.Title</span>
                        <span class="lib-hero-cover-author">@featured.Author</span>
                    </div>
                </div>
            </div>
            <div class="lib-hero-rail" role="tablist" aria-label="Trending titles">
                @for (var i = 0; i < TrendingItems.Count; i++)
                {
                    var index = i;
                    var item = TrendingItems[i];
                    <button type="button" role="tab" aria-selected="@(index == _featuredIndex)"
                            class="@($"lib-hero-thumb {LibraryCoverArt.CoverClass(item)}{(index == _featuredIndex ? " is-active" : "")}")"
                            style="@LibraryCoverArt.StyleFor(item)" title="@item.Title"
                            @onclick="@(() => SelectFeatured(index))">
                        <span class="lib-hero-thumb-title">@item.Title</span>
                    </button>
                }
            </div>
        </section>
    }

    <section class="lib-browse" aria-label="Browse catalog">
        <div class="lib-section-head">
            <h2 class="lib-section-title">Browse</h2>
            <span class="lib-section-rule" aria-hidden="true"></span>
            <span class="lib-result-count">
                @if (_loading)
                {
                    <text>Searching…</text>
                }
                else
                {
                    @($"{FilteredItems.Count} {(FilteredItems.Count == 1 ? "title" : "titles")}")
                }
            </span>
        </div>
        @if (!_loading && FilteredItems.Count == 0)
        {
            <div class="lib-empty">
                <span class="lib-empty-glyph" aria-hidden="true">⌀</span>
                <p class="lib-empty-title">Nothing on this shelf</p>
                <p class="lib-empty-sub">No titles match the current search and filters. Clear a filter or try another name.</p>
                <button type="button" class="lib-clear-btn" @onclick="ClearFilters">Clear all filters</button>
            </div>
        }
        else
        {
            <div class="lib-grid">
                @foreach (var item in FilteredItems)
                {
                    <MediaCard Item="item" OnTrack="TrackItem" OnProgressUpdated="OnProgressUpdatedAsync" />
                }
            </div>
            @if (CanLoadMore)
            {
                <div class="lib-load-more">
                    <button type="button" class="lib-load-more-btn" disabled="@_loadingMore" @onclick="LoadMoreAsync">
                        @(_loadingMore ? "Loading…" : $"Load more ({_trendingTotalCount - _trending.Count} remaining)")
                    </button>
                </div>
            }
        }
    </section>
</div>
