@page "/settings"
@using BookmarkManager.Contracts
@using BookmarkManager.Client.Components

<PageTitle>Settings</PageTitle>

<MudStack Spacing="4" Class="page-surface settings-page">
    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="page-heading">
        <div>
            <MudText Typo="Typo.h4">Settings</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Manage tracked folders, sync behavior, and extension connection status.
            </MudText>
        </div>
        <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Lan">
            LAN only
        </MudChip>
    </MudStack>

    <!-- Personalization / Theme Selection -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Palette" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Personalization</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Select your preferred color theme. Catppuccin is a cozy, high-contrast palette for reading.
            </MudText>
            <div class="theme-selection-grid">
                @foreach (var theme in _availableThemes)
                {
                    var active = theme.Id == _selectedThemeId;
                    <button class="theme-card @(active ? "active" : "")" 
                            @onclick="@(() => SelectThemeAsync(theme.Id))" 
                            type="button">
                        <div class="theme-preview-strip" style="background-color: @theme.BgColor; border-color: @theme.BorderColor;">
                            <span class="theme-dot" style="background-color: @theme.AccentColor;" title="Accent"></span>
                            <span class="theme-dot" style="background-color: @theme.TextColor;" title="Text"></span>
                        </div>
                        <div class="theme-details">
                            <span class="theme-name" style="color: @(active ? "var(--bm-accent)" : "var(--bm-text)");">@theme.Name</span>
                            <span class="theme-desc">@theme.Description</span>
                        </div>
                    </button>
                }
            </div>
        </MudStack>
    </MudPaper>

    <!-- Extension Connection Status Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Power" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Brave Extension Connection</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               OnClick="LoadExtensionStatusAsync"
                               Disabled="@_statusLoading" />
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Connection status and diagnostics from the Brave sync extension.
            </MudText>
            @if (_statusLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_extensionStatus == null)
            {
                <MudText Color="Color.Error" Class="pa-2">
                    Failed to fetch extension connection status. Make sure the API server is reachable.
                </MudText>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Connection Status</MudText>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <span class="status-dot @(_extensionStatus.IsConnected ? "is-online" : "is-offline")" style="margin-right: 4px;" aria-hidden="true"></span>
                                <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                    @(_extensionStatus.IsConnected ? "Connected" : "Offline")
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Extension Version</MudText>
                            <MudText Typo="Typo.body1" Style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;">
                                @(string.IsNullOrWhiteSpace(_extensionStatus.ExtensionVersion) ? "N/A" : _extensionStatus.ExtensionVersion)
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Brave Browser Version</MudText>
                            <MudText Typo="Typo.body1" Style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;">
                                @(string.IsNullOrWhiteSpace(_extensionStatus.BraveVersion) ? "N/A" : _extensionStatus.BraveVersion)
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Last Heartbeat</MudText>
                            <MudText Typo="Typo.body1">
                                @(_extensionStatus.LastHeartbeatAt.HasValue ? _extensionStatus.LastHeartbeatAt.Value.ToLocalTime().ToString("g") : "Never")
                            </MudText>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            }
        </MudStack>
    </MudPaper>


    <!-- AI Auto Tagging Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">AI Auto Tagging</MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Bolt"
                           OnClick="TestAiKeyAsync"
                           Disabled="@(_aiKeyTesting || _aiSettingsLoading)">
                    @(_aiKeyTesting ? "Testing..." : "Test key")
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="SaveAiTaggingSettingsAsync"
                           Disabled="@_aiSettingsSaving">
                    @(_aiSettingsSaving ? "Saving..." : "Save")
                </MudButton>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Configure OpenRouter for the Auto Tagger's AI series-title matching mode. Tags still come from source providers.
            </MudText>
            @if (_aiSettingsLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else
            {
                <MudCheckBox T="bool" @bind-Value="_aiSettings.Enabled" Label="Enable OpenRouter AI auto-tagging mode" Color="Color.Primary" />
                
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_aiSettings.BaseUrl"
                                      Label="Base URL"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      HelperText="OpenRouter API Base URL, e.g. https://openrouter.ai/api/v1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_aiSettings.Model"
                                      Label="Model"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      HelperText="OpenRouter model ID, e.g. google/gemini-2.5-flash:free" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_aiSettings.ApiKey"
                                      Label="OpenRouter API Key"
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Password"
                                      Immediate="true"
                                      HelperText="Stored locally on this API server." />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField @bind-Value="_aiSettings.RequestsPerMinute"
                                         Label="Requests Per Minute (RPM)"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="Pacing limit for API calls." />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField @bind-Value="_aiSettings.PreferredBatchSize"
                                         Label="Preferred Batch Size"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="Number of bookmarks to process per batch." />
                    </MudItem>
                </MudGrid>

                @if (_aiKeyTestResult is not null)
                {
                    <MudAlert Severity="@(_aiKeyTestResult.Success ? Severity.Success : Severity.Error)"
                              Variant="Variant.Outlined"
                              Dense="true"
                              ShowCloseIcon="true"
                              CloseIconClicked="@(() => _aiKeyTestResult = null)">
                        @(_aiKeyTestResult.StatusCode > 0 ? $"[{_aiKeyTestResult.StatusCode}] " : "")@_aiKeyTestResult.Message
                    </MudAlert>
                }

                <MudDivider Class="my-2" />

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.subtitle2" Class="flex-grow-1">Groq fallback (optional)</MudText>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Bolt"
                               OnClick="TestGroqKeyAsync"
                               Disabled="@(_groqKeyTesting || _aiSettingsLoading)">
                        @(_groqKeyTesting ? "Testing..." : "Test key")
                    </MudButton>
                </MudStack>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Used automatically for a chunk only when OpenRouter's free-tier quota is exhausted for the day. Leave the key blank to disable the fallback.
                </MudText>

                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_aiSettings.GroqBaseUrl"
                                      Label="Groq Base URL"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      HelperText="e.g. https://api.groq.com/openai/v1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_aiSettings.GroqModel"
                                      Label="Groq Model"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      HelperText="e.g. llama-3.3-70b-versatile" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_aiSettings.GroqApiKey"
                                      Label="Groq API Key"
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Password"
                                      Immediate="true"
                                      HelperText="Stored locally on this API server. Get one at console.groq.com/keys." />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField @bind-Value="_aiSettings.GroqRequestsPerMinute"
                                         Label="Groq Requests Per Minute (RPM)"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         HelperText="Pacing limit for Groq fallback calls." />
                    </MudItem>
                </MudGrid>

                @if (_groqKeyTestResult is not null)
                {
                    <MudAlert Severity="@(_groqKeyTestResult.Success ? Severity.Success : Severity.Error)"
                              Variant="Variant.Outlined"
                              Dense="true"
                              ShowCloseIcon="true"
                              CloseIconClicked="@(() => _groqKeyTestResult = null)">
                        @(_groqKeyTestResult.StatusCode > 0 ? $"[{_groqKeyTestResult.StatusCode}] " : "")@_groqKeyTestResult.Message
                    </MudAlert>
                }

                <MudDivider Class="my-2" />

                <MudText Typo="Typo.subtitle2">URL Migrator search</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_aiSettings.MigrationSearchModel"
                                      Label="Migration Search Model"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      Class="migration-search-model-field"
                                      HelperText="Groq model used for the URL Migrator search/rerank stage, e.g. groq/compound-mini." />
                    </MudItem>
                    <MudItem xs="12" sm="6" Class="d-flex flex-column justify-center">
                        <MudSwitch T="bool" @bind-Value="_aiSettings.MigrationAutoApproveHigh"
                                   Color="Color.Warning"
                                   Class="migration-auto-approve-switch"
                                   Label="Auto-approve verified (High) proposals" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            When enabled, High-confidence URL Migrator matches are approved automatically as soon as they're found. Wrong-series matches are still possible — review results periodically.
                        </MudText>
                    </MudItem>
                </MudGrid>
            }
        </MudStack>
    </MudPaper>


    <!-- Link Checker Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.LinkOff" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Broken Link Checker</MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           OnClick="RunLinkCheckerAsync"
                           Disabled="@_linkCheckerRunning">
                    @(_linkCheckerRunning ? "Checking..." : "Run Checker")
                </MudButton>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Scan your active bookmarks for dead domains or 404 pages. Broken links will be moved automatically to the "Broken Links" folder.
            </MudText>
            @if (_linkCheckerRunning)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
        </MudStack>
    </MudPaper>

    <!-- Domain Triage (manual folder move) & URL Migrator Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Domain Triage & URL Migrator</MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.SwapHoriz"
                           OnClick="OpenUrlMigrator"
                           Class="open-url-migrator-btn">
                    Open URL Migrator
                </MudButton>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Find all bookmarks matching a specific base URL and move them to a target folder for manual fixing.
                To automatically find and verify replacement links (AI-assisted), use the URL Migrator page instead.
            </MudText>

            <MudGrid>
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="_triageMatchBaseUrl"
                                  Label="Base URL to Match"
                                  Placeholder="e.g., https://reaperscans.com"
                                  Variant="Variant.Outlined"
                                  Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="4" Class="d-flex align-center">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="RunDomainTriageAsync"
                               Disabled="@_triageRunning"
                               FullWidth="true">
                        @(_triageRunning ? "Running..." : "Move to Folder")
                    </MudButton>
                </MudItem>
            </MudGrid>

            @if (_triageRunning)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }

            @if (!_triageRunning && _triageResult != null)
            {
                @if (!string.IsNullOrEmpty(_triageResult.ErrorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mt-2" OnClick="@(() => _triageResult = null)">
                        Triage failed: @_triageResult.ErrorMessage
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Class="mt-2" OnClick="@(() => _triageResult = null)">
                        Triage completed successfully! Matched @_triageResult.TotalFound bookmarks. Processed @_triageResult.SuccessfullyProcessed bookmarks into folder "@_triageResult.TargetFolder".
                    </MudAlert>
                }
            }
        </MudStack>
    </MudPaper>

    <!-- Library Release Watcher Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Update" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Library Release Watcher</MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           OnClick="RunReleaseWatcherAsync"
                           Disabled="@_watcherRunning">
                    @(_watcherRunning ? "Checking..." : "Check Releases Now")
                </MudButton>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Diagnostics and status for the background release watcher.
            </MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudNumericField T="int"
                                 Label="Check interval (hours)"
                                 @bind-Value="_watcherSettings.IntervalHours"
                                 Min="1"
                                 Max="168"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Style="max-width: 220px;" />
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           OnClick="SaveWatcherSettingsAsync"
                           Disabled="@_watcherSettingsSaving">
                    @(_watcherSettingsSaving ? "Saving..." : "Save Schedule")
                </MudButton>
            </MudStack>

            @if (_watcherStatusLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_watcherStatus != null)
            {
                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Status</MudText>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <span class="status-dot @(_watcherStatus.IsRunning ? "is-running" : "is-idle")" style="margin-right: 4px;" aria-hidden="true"></span>
                                <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                    @(_watcherStatus.IsRunning ? "Running" : "Idle")
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Total Tracked Series</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                @_watcherStatus.TotalTrackedCount
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Successful Checks</MudText>
                            <MudText Typo="Typo.body1" Color="Color.Success" Style="font-weight: 600;">
                                @_watcherStatus.SuccessCount
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Failed Checks</MudText>
                            <MudText Typo="Typo.body1" Color="Color.Error" Style="font-weight: 600;">
                                @_watcherStatus.FailureCount
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Last Checked Time</MudText>
                            <MudText Typo="Typo.body2">
                                @(_watcherStatus.LastRunTime?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Never")
                            </MudText>
                        </MudStack>
                    </MudItem>
                    @if (!string.IsNullOrEmpty(_watcherStatus.LastError))
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                                Last Error: @_watcherStatus.LastError
                            </MudAlert>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudStack>
    </MudPaper>

    <!-- Library Catalog Sync Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.CloudSync" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Library Catalog Sync</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               OnClick="LoadCatalogSyncStatusAsync"
                               Disabled="@_catalogStatusLoading" />
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Sync"
                           OnClick="TriggerCatalogResyncAsync"
                           Disabled="@_catalogResyncTriggering">
                    @(_catalogResyncTriggering ? "Starting..." : "Force Full Resync")
                </MudButton>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Background crawl that mirrors AniList/MangaDex catalogs locally so the Library "Browse" view can
                page through the full catalog instead of a live top-N call. A full resync can take a while due to
                provider rate limits; progress resumes automatically if the app restarts mid-crawl.
            </MudText>

            @if (_catalogStatusLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_catalogStatus != null)
            {
                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Status</MudText>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <span class="status-dot @(_catalogStatus.IsCrawling ? "is-running" : "is-idle")" style="margin-right: 4px;" aria-hidden="true"></span>
                                <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                    @(_catalogStatus.IsCrawling ? "Crawling" : "Idle")
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Cached Titles</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                @_catalogStatus.TotalEntries
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Queue (Pending / Processing)</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                @_catalogStatus.PendingQueueCount / @_catalogStatus.ProcessingQueueCount
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Failed Queue Items</MudText>
                            <MudText Typo="Typo.body1" Color="@(_catalogStatus.FailedQueueCount > 0 ? Color.Error : Color.Default)" Style="font-weight: 600;">
                                @_catalogStatus.FailedQueueCount
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Last Refreshed</MudText>
                            <MudText Typo="Typo.body2">
                                @(_catalogStatus.LastRefreshedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "Never")
                            </MudText>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            }
        </MudStack>
    </MudPaper>

    <!-- Provider Health & Toggles Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.LocalHospital" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Provider Health & Diagnostics</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               OnClick="LoadProviderHealthAsync"
                               Disabled="@_healthLoading" />
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Monitor health, status, and network request budgets per media catalog provider.
            </MudText>

            @if (_healthLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 16px;">
                    @foreach (var provider in _providerHealth)
                    {
                        var current = provider;
                        <div style="display: flex; align-items: flex-start; justify-content: space-between; padding: 12px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 6px;">
                            <div style="display: flex; flex-direction: column; gap: 4px;">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: bold; color: var(--bm-text-primary);">
                                        @current.ProviderName
                                    </MudText>
                                    <span class="status-badge @(current.IsEnabled ? "status-badge--success" : "status-badge--danger")" style="padding: 2px 6px; font-size: 0.7rem; line-height: 1;">
                                        @(current.IsEnabled ? "Enabled" : "Disabled")
                                    </span>
                                </div>
                                <div style="display: flex; gap: 16px; font-size: 0.8rem; color: var(--bm-text-secondary); margin-top: 4px;">
                                    <span>Successes: <strong style="color: var(--mud-palette-success);">@current.SuccessCount</strong></span>
                                    <span>Failures: <strong style="color: var(--mud-palette-error);">@current.FailureCount</strong></span>
                                    <span>Network: <strong>@current.NetworkCalls</strong></span>
                                    <span>Cache Hits: <strong>@current.CacheHits</strong></span>
                                </div>
                                @if (current.LastSuccess.HasValue)
                                {
                                    <span style="font-size: 0.75rem; color: var(--bm-text-secondary);">Last Success: @current.LastSuccess.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                                }
                                @if (!string.IsNullOrEmpty(current.LastError))
                                {
                                    <div style="margin-top: 4px; font-size: 0.75rem; color: var(--mud-palette-error); font-family: monospace; background: rgba(244,67,54,0.05); padding: 4px 8px; border-radius: 4px;">
                                        Last Error: @current.LastError
                                        @if (current.LastFailure.HasValue)
                                        {
                                            <span style="display: block; font-size: 0.7rem; opacity: 0.8;">At: @current.LastFailure.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                                        }
                                    </div>
                                }
                            </div>
                            <div style="display: flex; align-items: center;">
                                <MudSwitch T="bool" Value="@current.IsEnabled" ValueChanged="@((bool val) => ToggleProviderAsync(current.ProviderName, val))" Color="Color.Primary" Label="Active" />
                            </div>
                        </div>
                    }
                </div>
            }
        </MudStack>
    </MudPaper>

</MudStack>
