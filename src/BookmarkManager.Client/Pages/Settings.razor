@page "/settings"
@using BookmarkManager.Contracts
@using BookmarkManager.Client.Components

<PageTitle>Settings</PageTitle>

<MudStack Spacing="4" Class="page-surface settings-page">
    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="page-heading">
        <div>
            <MudText Typo="Typo.h4">Settings</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Manage tracked folders, sync behavior, and extension connection status.
            </MudText>
        </div>
        <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Lan">
            LAN only
        </MudChip>
    </MudStack>

    <!-- Extension Connection Status Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Power" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Brave Extension Connection</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               OnClick="LoadExtensionStatusAsync"
                               Disabled="@_statusLoading" />
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Connection status and diagnostics from the Brave sync extension.
            </MudText>
            @if (_statusLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_extensionStatus == null)
            {
                <MudText Color="Color.Error" Class="pa-2">
                    Failed to fetch extension connection status. Make sure the API server is reachable.
                </MudText>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Connection Status</MudText>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <span class="status-dot @(_extensionStatus.IsConnected ? "is-online" : "is-offline")" style="margin-right: 4px;" aria-hidden="true"></span>
                                <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                    @(_extensionStatus.IsConnected ? "Connected" : "Offline")
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Extension Version</MudText>
                            <MudText Typo="Typo.body1" Style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;">
                                @(string.IsNullOrWhiteSpace(_extensionStatus.ExtensionVersion) ? "N/A" : _extensionStatus.ExtensionVersion)
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Brave Browser Version</MudText>
                            <MudText Typo="Typo.body1" Style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;">
                                @(string.IsNullOrWhiteSpace(_extensionStatus.BraveVersion) ? "N/A" : _extensionStatus.BraveVersion)
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Last Heartbeat</MudText>
                            <MudText Typo="Typo.body1">
                                @(_extensionStatus.LastHeartbeatAt.HasValue ? _extensionStatus.LastHeartbeatAt.Value.ToLocalTime().ToString("g") : "Never")
                            </MudText>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            }
        </MudStack>
    </MudPaper>


    <!-- Link Checker Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.LinkOff" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Broken Link Checker</MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           OnClick="RunLinkCheckerAsync"
                           Disabled="@_linkCheckerRunning">
                    @(_linkCheckerRunning ? "Checking..." : "Run Checker")
                </MudButton>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Scan your active bookmarks for dead domains or 404 pages. Broken links will be moved automatically to the "Broken Links" folder.
            </MudText>
            @if (_linkCheckerRunning)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
        </MudStack>
    </MudPaper>


</MudStack>
