@page "/settings"
@using BookmarkManager.Contracts
@using BookmarkManager.Client.Components

<PageTitle>Settings</PageTitle>

<MudStack Spacing="4" Class="page-surface settings-page">
    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="page-heading">
        <div>
            <MudText Typo="Typo.h4">Settings</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Manage tracked folders, sync behaviour, and preferences.
            </MudText>
        </div>
        <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Lan">
            LAN only
        </MudChip>
    </MudStack>

    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Uploaded folder candidates</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               OnClick="LoadFolderCandidatesAsync"
                               Disabled="@_foldersLoading" />
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Folders the Brave extension reported during its last heartbeat. Choose which become tracked roots below.
            </MudText>
            @if (_foldersLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_folderCandidates.Count == 0)
            {
                <MudText Color="Color.Default" Class="pa-2">
                    No folder catalog received yet. Pair the extension and trigger a heartbeat.
                </MudText>
            }
            else
            {
                <MudTable Items="_folderCandidates" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Folder</MudTh>
                        <MudTh>Browser node</MudTh>
                        <MudTh>Position</MudTh>
                        <MudTh>Flags</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="candidate">
                        <MudTd DataLabel="Folder">@candidate.Title</MudTd>
                        <MudTd DataLabel="Browser node"><code>@candidate.BrowserNodeId</code></MudTd>
                        <MudTd DataLabel="Position">@candidate.Position</MudTd>
                        <MudTd DataLabel="Flags">
                            @if (candidate.IsProtected)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Class="mr-1">Protected</MudChip>
                            }
                            @if (candidate.IsTracked)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Tracked</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       Disabled="@(candidate.IsProtected || candidate.IsTracked)"
                                       OnClick="@(() => AddTrackedRootAsync(candidate))">
                                Track
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudStack>
    </MudPaper>

    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Bookmarks" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Tracked roots</MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Warning"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Build"
                           OnClick="PromptRepairAsync">
                    Repair snapshot
                </MudButton>
            </MudStack>
            <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                Repair asks the extension for a Brave-wins snapshot. Use it only when the server projection is clearly stale.
            </MudAlert>
            @if (_rootsLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_trackedRoots.Count == 0)
            {
                <MudText Color="Color.Default" Class="pa-2">No tracked roots configured yet.</MudText>
            }
            else
            {
                <MudTable Items="_trackedRoots" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Root</MudTh>
                        <MudTh>Default category</MudTh>
                        <MudTh>Added</MudTh>
                        <MudTh>Last sync</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="root">
                        <MudTd DataLabel="Root">@root.Title</MudTd>
                        <MudTd DataLabel="Default category">
                            <MudSelect T="string" Value="@DefaultCategory(root.Title)" Dense="true" Margin="Margin.Dense" Class="settings-category-select">
                                <MudSelectItem Value="@("Manga")">Manga</MudSelectItem>
                                <MudSelectItem Value="@("Novels")">Novels</MudSelectItem>
                                <MudSelectItem Value="@("Anime")">Anime</MudSelectItem>
                                <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                            </MudSelect>
                        </MudTd>
                        <MudTd DataLabel="Added">@root.AddedAt.ToLocalTime().ToString("g")</MudTd>
                        <MudTd DataLabel="Last sync">@(root.LastSyncedAt == DateTime.MinValue ? "Never" : root.LastSyncedAt.ToLocalTime().ToString("g"))</MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudIconButton Icon="@Icons.Material.Filled.Sync"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           OnClick="@(() => SyncRootAsync(root.Id))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => PromptRemoveRootAsync(root.Id, root.Title))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudStack>
    </MudPaper>

    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.LinkOff" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Broken Link Checker</MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           OnClick="RunLinkCheckerAsync"
                           Disabled="@_linkCheckerRunning">
                    @(_linkCheckerRunning ? "Checking..." : "Run Checker")
                </MudButton>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Scan your active bookmarks for dead domains or 404 pages. Broken links will be moved automatically to the "Broken Links" folder.
            </MudText>
            @if (_linkCheckerRunning)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
        </MudStack>
    </MudPaper>

    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Theme and density</MudText>
            </MudStack>
            <MudStack Row="true" Spacing="3" Class="settings-preferences">
                <MudSelect T="string" @bind-Value="_themePreference" Label="Theme" Dense="true" Margin="Margin.Dense">
                    <MudSelectItem Value="@("System")">System</MudSelectItem>
                    <MudSelectItem Value="@("Light")">Light</MudSelectItem>
                    <MudSelectItem Value="@("Dark")">Dark</MudSelectItem>
                </MudSelect>
                <MudSelect T="string" @bind-Value="_densityPreference" Label="Density" Dense="true" Margin="Margin.Dense">
                    <MudSelectItem Value="@("Comfortable")">Comfortable</MudSelectItem>
                    <MudSelectItem Value="@("Compact")">Compact</MudSelectItem>
                </MudSelect>
                <MudSwitch T="bool" @bind-Value="_showSyncHints" Label="Show sync explanations" Color="Color.Primary" />
            </MudStack>
        </MudStack>
    </MudPaper>
</MudStack>
