@page "/settings"
@using BookmarkManager.Contracts
@using BookmarkManager.Client.Components

<PageTitle>Settings</PageTitle>

<MudStack Spacing="4" Class="page-surface settings-page">
    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="page-heading">
        <div>
            <MudText Typo="Typo.h4">Settings</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Manage tracked folders, sync behavior, and extension connection status.
            </MudText>
        </div>
        <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Lan">
            LAN only
        </MudChip>
    </MudStack>

    <!-- Extension Connection Status Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Power" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Brave Extension Connection</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               OnClick="LoadExtensionStatusAsync"
                               Disabled="@_statusLoading" />
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Connection status and diagnostics from the Brave sync extension.
            </MudText>
            @if (_statusLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_extensionStatus == null)
            {
                <MudText Color="Color.Error" Class="pa-2">
                    Failed to fetch extension connection status. Make sure the API server is reachable.
                </MudText>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Connection Status</MudText>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <span class="status-dot @(_extensionStatus.IsConnected ? "is-online" : "is-offline")" style="margin-right: 4px;" aria-hidden="true"></span>
                                <MudText Typo="Typo.body1" Style="font-weight: 600;">
                                    @(_extensionStatus.IsConnected ? "Connected" : "Offline")
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Extension Version</MudText>
                            <MudText Typo="Typo.body1" Style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;">
                                @(string.IsNullOrWhiteSpace(_extensionStatus.ExtensionVersion) ? "N/A" : _extensionStatus.ExtensionVersion)
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Brave Browser Version</MudText>
                            <MudText Typo="Typo.body1" Style="font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;">
                                @(string.IsNullOrWhiteSpace(_extensionStatus.BraveVersion) ? "N/A" : _extensionStatus.BraveVersion)
                            </MudText>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Last Heartbeat</MudText>
                            <MudText Typo="Typo.body1">
                                @(_extensionStatus.LastHeartbeatAt.HasValue ? _extensionStatus.LastHeartbeatAt.Value.ToLocalTime().ToString("g") : "Never")
                            </MudText>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            }
        </MudStack>
    </MudPaper>

    <!-- Uploaded Folder Candidates Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Uploaded folder candidates</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               OnClick="LoadFolderCandidatesAsync"
                               Disabled="@_foldersLoading" />
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Folders the Brave extension reported during its last heartbeat. Choose which become tracked roots below.
            </MudText>
            @if (_foldersLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_folderCandidates.Count == 0)
            {
                <MudText Color="Color.Default" Class="pa-2">
                    No folder catalog received yet. Pair the extension and trigger a heartbeat.
                </MudText>
            }
            else
            {
                <MudTable Items="_folderCandidates" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Folder</MudTh>
                        <MudTh>Browser node</MudTh>
                        <MudTh>Position</MudTh>
                        <MudTh>Flags</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="candidate">
                        <MudTd DataLabel="Folder">@candidate.Title</MudTd>
                        <MudTd DataLabel="Browser node"><code>@candidate.BrowserNodeId</code></MudTd>
                        <MudTd DataLabel="Position">@candidate.Position</MudTd>
                        <MudTd DataLabel="Flags">
                            @if (candidate.IsProtected)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" Class="mr-1">Protected</MudChip>
                            }
                            @if (candidate.IsTracked)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Tracked</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       Disabled="@(candidate.IsProtected || candidate.IsTracked)"
                                       OnClick="@(() => AddTrackedRootAsync(candidate))">
                                Track
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudStack>
    </MudPaper>

    <!-- Tracked Roots Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Bookmarks" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Tracked roots</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Tracked roots currently synchronizing with the database. Trigger a manual sync or queue a Brave-wins repair snapshot.
            </MudText>
            @if (_rootsLoading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_trackedRoots.Count == 0)
            {
                <MudText Color="Color.Default" Class="pa-2">No tracked roots configured yet.</MudText>
            }
            else
            {
                <MudTable Items="_trackedRoots" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Root</MudTh>
                        <MudTh>Added</MudTh>
                        <MudTh>Last sync</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="root">
                        <MudTd DataLabel="Root">@root.Title</MudTd>
                        <MudTd DataLabel="Added">@root.AddedAt.ToLocalTime().ToString("g")</MudTd>
                        <MudTd DataLabel="Last sync">@(root.LastSyncedAt == DateTime.MinValue ? "Never" : root.LastSyncedAt.ToLocalTime().ToString("g"))</MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudIconButton Icon="@Icons.Material.Filled.Sync"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Title="Sync Root"
                                           OnClick="@(() => SyncRootAsync(root.Id))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Build"
                                           Color="Color.Warning"
                                           Size="Size.Small"
                                           Title="Repair Snapshot (Brave wins)"
                                           OnClick="@(() => PromptRepairRootAsync(root.Id, root.Title))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Title="Stop Tracking"
                                           OnClick="@(() => PromptRemoveRootAsync(root.Id, root.Title))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudStack>
    </MudPaper>

    <!-- Link Checker Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.LinkOff" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Broken Link Checker</MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           OnClick="RunLinkCheckerAsync"
                           Disabled="@_linkCheckerRunning">
                    @(_linkCheckerRunning ? "Checking..." : "Run Checker")
                </MudButton>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Scan your active bookmarks for dead domains or 404 pages. Broken links will be moved automatically to the "Broken Links" folder.
            </MudText>
            @if (_linkCheckerRunning)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
        </MudStack>
    </MudPaper>

    <!-- AI Tagging Settings Section -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">AI Tagging Settings</MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="SaveAiSettingsAsync"
                           Disabled="@(_aiSettingsLoading || _aiSettingsSaving)">
                    @(_aiSettingsSaving ? "Saving..." : "Save Settings")
                </MudButton>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Configure your custom OpenAI-compatible AI provider (OpenAI, Ollama, OpenRouter, LM Studio, etc.) for smart bookmark tagging.
            </MudText>
            
            @if (_aiSettingsLoading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12">
                        <MudSwitch T="bool" @bind-Value="_aiSettings.Enabled" Label="Enable AI Tagging" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="string" Value="_selectedProvider" ValueChanged="OnProviderChanged" Label="AI Provider" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@("OpenAI")">OpenAI</MudSelectItem>
                            <MudSelectItem Value="@("OpenRouter")">OpenRouter</MudSelectItem>
                            <MudSelectItem Value="@("Ollama")">Ollama (Local)</MudSelectItem>
                            <MudSelectItem Value="@("Custom")">Custom Provider...</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="string" Value="_selectedModel" ValueChanged="OnModelChanged" Label="Model Selection" Variant="Variant.Outlined" Margin="Margin.Dense">
                            @foreach (var m in GetModelsForProvider(_selectedProvider))
                            {
                                <MudSelectItem Value="@m">@m</MudSelectItem>
                            }
                            <MudSelectItem Value="@("Custom")">Custom Model...</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    @if (_selectedProvider != "Ollama")
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudTextField @bind-Value="_aiSettings.ApiKey" Label="API Key" InputType="InputType.Password" Placeholder="Enter your API Key" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    }
                    @if (_customModelActive)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudTextField @bind-Value="_aiSettings.Model" Label="Custom Model Name" Placeholder="e.g. custom-model:latest" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    }
                    @if (_selectedProvider == "Custom")
                    {
                        <MudItem xs="12" sm="12" md="8">
                            <MudTextField @bind-Value="_aiSettings.Endpoint" Label="Custom API Endpoint URL" Placeholder="https://example.com/v1/chat/completions" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudStack>
    </MudPaper>
</MudStack>
