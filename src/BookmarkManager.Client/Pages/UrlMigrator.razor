@page "/url-migrator"
@using BookmarkManager.Contracts

<PageTitle>URL Migrator</PageTitle>

<MudStack Spacing="4" Class="page-surface url-migrator-page">
    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="page-heading">
        <div>
            <MudText Typo="Typo.h4">URL Migrator</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Find working replacement links for bookmarks stuck on dead domains, verify them, then approve or reject.
            </MudText>
        </div>
    </MudStack>

    <!-- Section 1: Start a migration -->
    <MudPaper Elevation="0" Class="ops-panel">
        <MudStack Spacing="3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="migrator-panel-header">
                <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="flex-grow-1">Detected dead domains</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               OnClick="LoadDeadDomainsAsync"
                               Disabled="@_loadingDeadDomains"
                               Class="migrator-refresh-btn" />
            </MudStack>

            @if (_loadingDeadDomains)
            {
                <MudProgressLinear Indeterminate="true" Class="migrator-progress-bar" />
            }
            else if (_deadDomains.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    None detected — run Link Checker, or enter a domain manually below.
                </MudText>
            }
            else
            {
                <div class="migrator-dead-domains-list" role="list" aria-label="Detected dead domains">
                    @foreach (var domain in _deadDomains)
                    {
                        <div class="migrator-dead-domain-row" role="listitem">
                            <span class="migrator-domain-host">@domain.Host</span>
                            <span class="migrator-domain-count">@domain.BookmarkCount bookmarks</span>
                            <button type="button" class="migrator-migrate-btn"
                                    disabled="@(IsRunning || _starting)"
                                    @onclick="@(() => StartMigrationFromListAsync(domain.Host))">
                                Migrate <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                            </button>
                        </div>
                    }
                </div>
            }

            <MudDivider Class="my-2" />

            <MudText Typo="Typo.body2">Or enter a domain manually:</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="migrator-manual-row">
                <MudAutocomplete T="string"
                                 @bind-Value="_manualHost"
                                 SearchFunc="SearchHostsAsync"
                                 Label="Host"
                                 Placeholder="e.g. flamecomics.xyz"
                                 Variant="Variant.Outlined"
                                 Immediate="true"
                                 MinCharacters="2"
                                 DebounceInterval="250"
                                 ShowProgressIndicator="true"
                                 Disabled="@(IsRunning || _starting)"
                                 Class="migrator-manual-host-field" />
                <MudTextField @bind-Value="_suggestedTargetHost"
                              Label="Migrate to (optional)"
                              Placeholder="e.g. weebcentral.com"
                              Variant="Variant.Outlined"
                              Immediate="true"
                              Disabled="@(IsRunning || _starting)"
                              Class="migrator-suggested-host-field" />
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="StartMigrationFromFieldAsync"
                           Disabled="@(IsRunning || _starting || string.IsNullOrWhiteSpace(_manualHost))"
                           Class="migrator-start-btn">
                    @(_starting ? "Starting..." : "Start Migration")
                </MudButton>
            </MudStack>
            @if (!string.IsNullOrWhiteSpace(_suggestedTargetHost))
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Search will be restricted to @_suggestedTargetHost instead of the open web.
                </MudText>
            }
        </MudStack>
    </MudPaper>

    <!-- Section 2: Run progress -->
    @if (_status != null && (IsRunning || _status.TotalFound > 0 || !string.IsNullOrEmpty(_status.ErrorMessage)))
    {
        <MudPaper Elevation="0" Class="ops-panel migrator-progress-panel">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">
                    @(IsRunning ? "Migrating " : "Last run: ")<span class="migrator-progress-host">@_status.DeadHost</span>
                </MudText>
                @if (IsRunning || _status.TotalFound > 0)
                {
                    <MudProgressLinear Value="@(ProgressPercent())" Color="Color.Primary" Class="migrator-progress-bar" />
                    <MudText Typo="Typo.body2">@_status.Processed / @_status.TotalFound processed</MudText>
                }
                @if (!string.IsNullOrEmpty(_status.CurrentBookmarkTitle))
                {
                    <MudText Typo="Typo.body2" Class="migrator-resolving-line">Resolving: "@_status.CurrentBookmarkTitle"</MudText>
                }
                <div class="migrator-stat-row">
                    <span class="migrator-stat-pill">Resolved <strong>@_status.Resolved</strong></span>
                    <span class="migrator-stat-pill">Unresolved <strong>@_status.Unresolved</strong></span>
                </div>
                @if (!string.IsNullOrEmpty(_status.ErrorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">@_status.ErrorMessage</MudAlert>
                }
            </MudStack>
        </MudPaper>
    }

    <!-- Section 3: Review -->
    <MudPaper Elevation="0" Class="ops-panel migrator-review-panel">
        <MudTabs @bind-ActivePanelIndex="_activeTabIndex" Class="migrator-tabs">
            <MudTabPanel Text="Current run">
                @if (OrphanedPendingProposals.Count > 0)
                {
                    <MudAlert Severity="Severity.Info" Class="mb-2 migrator-orphaned-alert">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%;">
                            <MudText Typo="Typo.body2">
                                @OrphanedPendingProposals.Count proposal(s) from an earlier run are still pending review.
                                They're excluded from new migrations for their host until you decide them.
                            </MudText>
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Warning"
                                       Size="Size.Small"
                                       OnClick="CancelAllOrphanedAsync"
                                       Class="migrator-cancel-all-orphaned-btn">
                                Cancel all (@OrphanedPendingProposals.Count)
                            </MudButton>
                        </MudStack>
                    </MudAlert>
                    <MudExpansionPanels Class="migrator-groups mb-3">
                        <MudExpansionPanel Class="migrator-group migrator-orphaned-group" Text="@($"Pending from earlier runs — {OrphanedPendingProposals.Count} bookmark(s)")">
                            <ChildContent>
                                @foreach (var proposal in OrphanedPendingProposals)
                                {
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="migrator-proposal-row pa-2">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body1">@proposal.BookmarkTitle</MudText>
                                            <MudText Typo="Typo.caption" Class="migrator-url-text">old: @(proposal.OldUrl ?? "(none)")</MudText>
                                            <MudText Typo="Typo.caption" Class="migrator-url-text">new: @(proposal.ProposedUrl ?? "(none)")</MudText>
                                            @if (!string.IsNullOrEmpty(proposal.Detail))
                                            {
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary migrator-detail">@proposal.Detail</MudText>
                                            }
                                        </MudStack>
                                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                            <span class="status-badge @ConfidenceBadgeClass(proposal.Confidence)">@proposal.Confidence</span>
                                            <div class="migrator-row-actions">
                                                <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                               Color="Color.Success"
                                                               Size="Size.Small"
                                                               Class="migrator-approve-btn"
                                                               Disabled="@string.IsNullOrEmpty(proposal.ProposedUrl)"
                                                               OnClick="@(() => ApproveAsync([proposal.Id]))" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                               Color="Color.Error"
                                                               Size="Size.Small"
                                                               Class="migrator-reject-btn"
                                                               title="Reject — decline this proposed URL, won't be re-suggested"
                                                               OnClick="@(() => RejectAsync([proposal.Id]))" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                               Color="Color.Warning"
                                                               Size="Size.Small"
                                                               Class="migrator-cancel-btn"
                                                               title="Cancel — void this proposal, rerun fresh next time"
                                                               OnClick="@(() => CancelAsync([proposal.Id]))" />
                                                @if (!string.IsNullOrEmpty(proposal.ProposedUrl))
                                                {
                                                    <MudLink Href="@proposal.ProposedUrl" Target="_blank" rel="noopener" Class="migrator-open-link">
                                                        <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" />
                                                    </MudLink>
                                                }
                                            </div>
                                        </MudStack>
                                    </MudStack>
                                }
                            </ChildContent>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }

                @if (_currentProposals.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary pa-2">
                        No proposals yet. Start a migration above to see review results here.
                    </MudText>
                }
                else
                {
                    <MudExpansionPanels Class="migrator-groups">
                        @foreach (var group in PendingGroups)
                        {
                            var groupList = group.ToList();
                            <MudExpansionPanel Class="migrator-group">
                                <TitleContent>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="migrator-group-header" Style="width:100%;">
                                        <MudText Typo="Typo.subtitle1">@group.Key — @groupList.Count proposal(s)</MudText>
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Success"
                                                   Size="Size.Small"
                                                   OnClick="@(() => ApproveAsync(groupList.Select(p => p.Id)))"
                                                   Class="migrator-approve-group-btn">
                                            Approve @groupList.Count
                                        </MudButton>
                                    </MudStack>
                                </TitleContent>
                                <ChildContent>
                                    @foreach (var proposal in groupList)
                                    {
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="migrator-proposal-row pa-2">
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body1">@proposal.BookmarkTitle</MudText>
                                                <MudText Typo="Typo.caption" Class="migrator-url-text">old: @(proposal.OldUrl ?? "(none)")</MudText>
                                                <MudText Typo="Typo.caption" Class="migrator-url-text">new: @(proposal.ProposedUrl ?? "(none)")</MudText>
                                                @if (proposal.Confidence == "Medium" && !string.IsNullOrEmpty(proposal.Detail))
                                                {
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary migrator-detail">@proposal.Detail</MudText>
                                                }
                                            </MudStack>
                                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                                <span class="status-badge @ConfidenceBadgeClass(proposal.Confidence)">@proposal.Confidence</span>
                                                <div class="migrator-row-actions">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                                   Color="Color.Success"
                                                                   Size="Size.Small"
                                                                   Class="migrator-approve-btn"
                                                                   OnClick="@(() => ApproveAsync([proposal.Id]))" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                                   Color="Color.Error"
                                                                   Size="Size.Small"
                                                                   Class="migrator-reject-btn"
                                                                   OnClick="@(() => RejectAsync([proposal.Id]))" />
                                                    <MudLink Href="@proposal.ProposedUrl" Target="_blank" rel="noopener" Class="migrator-open-link">
                                                        <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" />
                                                    </MudLink>
                                                </div>
                                            </MudStack>
                                        </MudStack>
                                    }
                                </ChildContent>
                            </MudExpansionPanel>
                        }

                        @if (UnresolvedProposals.Count > 0)
                        {
                            <MudExpansionPanel Class="migrator-group migrator-unresolved-group" Text="@($"Unresolved — {UnresolvedProposals.Count} bookmark(s)")">
                                <ChildContent>
                                    @foreach (var proposal in UnresolvedProposals)
                                    {
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="migrator-proposal-row migrator-unresolved-row pa-2">
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body1">@proposal.BookmarkTitle</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@(proposal.Detail ?? "No reader found.")</MudText>
                                            </MudStack>
                                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                <span class="status-badge status-badge--watching">Unresolved</span>
                                                <MudButton Variant="Variant.Text"
                                                           Size="Size.Small"
                                                           Class="migrator-manual-url-btn"
                                                           OnClick="@(() => OpenManualUrlDialogAsync(proposal))">
                                                    Enter URL manually…
                                                </MudButton>
                                            </MudStack>
                                        </MudStack>
                                    }
                                </ChildContent>
                            </MudExpansionPanel>
                        }
                    </MudExpansionPanels>

                    <MudStack Row="true" Spacing="2" Class="mt-3 migrator-review-footer">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Disabled="@(HighConfidencePending.Count == 0)"
                                   OnClick="ApproveAllHighAsync"
                                   Class="migrator-approve-all-high-btn">
                            Approve all High (@HighConfidencePending.Count)
                        </MudButton>
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Error"
                                   Disabled="@(!_currentProposals.Any(p => p.Status == "Pending"))"
                                   OnClick="RejectRemainingAsync"
                                   Class="migrator-reject-remaining-btn">
                            Reject remaining
                        </MudButton>
                    </MudStack>
                }
            </MudTabPanel>

            <MudTabPanel Text="History">
                @if (HistoryProposals.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary pa-2">No decided proposals yet.</MudText>
                }
                else
                {
                    <MudSimpleTable Class="migrator-history-table" Dense="true">
                        <thead>
                            <tr>
                                <th>Bookmark</th>
                                <th>Host</th>
                                <th>Status</th>
                                <th>Decided</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var proposal in HistoryProposals)
                            {
                                <tr class="migrator-history-row" data-status="@proposal.Status">
                                    <td>@proposal.BookmarkTitle</td>
                                    <td class="migrator-host-cell">@proposal.ProposedHost</td>
                                    <td><span class="status-badge @HistoryStatusBadgeClass(proposal.Status)">@proposal.Status</span></td>
                                    <td>@(proposal.CreatedAt.ToLocalTime().ToString("g"))</td>
                                    <td>
                                        @if (proposal.Status == "Approved")
                                        {
                                            <MudButton Variant="Variant.Text"
                                                       Size="Size.Small"
                                                       Class="migrator-edit-bookmark-btn"
                                                       OnClick="@(() => EditBookmarkAsync(proposal))">
                                                Edit
                                            </MudButton>
                                            <MudButton Variant="Variant.Text"
                                                       Size="Size.Small"
                                                       Class="migrator-revert-btn"
                                                       OnClick="@(() => RevertAsync(proposal.Id))">
                                                Revert
                                            </MudButton>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </MudTabPanel>
        </MudTabs>
    </MudPaper>
</MudStack>

@code {
    private int _activeTabIndex;

    private double ProgressPercent()
        => _status == null || _status.TotalFound == 0
            ? 0
            : Math.Clamp(_status.Processed * 100.0 / _status.TotalFound, 0, 100);

}
